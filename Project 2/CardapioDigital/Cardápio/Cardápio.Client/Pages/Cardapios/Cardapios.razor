@page "/cardapios";

@inject HttpClient HttpClient;
@inject NavigationManager NavigationManager;

@using System.Collections.ObjectModel;
@using System.Net.Http.Json;
@using Cardápio.Client.Dto;

<head>
    @* <HeadOutlet /> *@
    @* <PageTitle>Seus Cardápios | Escolha AI</PageTitle> *@
    <title>Seus Cardápios | Escolha AI</title>
</head>

<div class="container-title-header">
    <i class="fa-solid fa-list"></i>
    <h3 class="title-page-section">Cardápios</h3>
</div>

@if (isLoading)
{
    <div class="container">
        @* <SpinnerLoader PrimaryColor="#272A2D" SecondaryColor="#ffffff" Size="90" /> *@
        <div>Carregando...</div>
    </div>
}

<div class="companies">
    <div class="container-companies">
        @foreach (var empresa in empresas)
        {
            <div class="company-card">
                <div class="banner-section">
                    <div class="image" alt="img" style="background-image: url('/imagens/banner/@empresa.ImageBanner?timestamp=@DateTime.Now.Ticks');"></div>
                </div>
                <div class="content-section">
                    <div class="logo">
                        <div class="image" style="background-image: url('/imagens/logo/@empresa.ImageLogo');"></div>
                    </div>
                    <div class="info">
                        <p>@empresa.Cidade.CidNome - @empresa.EstadoID</p>
                        <h3>@empresa.Nome</h3>
                    </div>
                    <div class="button-section">
                        <button class="menu-button rz-ripple" @onclick="() => RedirectPage(empresa.Nome)">Ver cardápio <i class="fa-solid fa-arrow-right"></i></button>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@code {
    private bool isLoading = true;
    private ObservableCollection<EmpresaGetDTO> empresas = new();
    string token = "";

    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
        {
            // token = await Provider.GetTokenAsync();
            GetData();
        }
    }

    async void GetData()
    {
        try
        {
            // HttpClient.DefaultRequestHeaders.Authorization =
            //     new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);

            var result = await HttpClient.GetFromJsonAsync<List<EmpresaGetDTO>>("/api/enterprise/GetEnterprises");
            empresas = new ObservableCollection<EmpresaGetDTO>(result ?? new List<EmpresaGetDTO>());
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    void RedirectPage(string companyName)
    {
        string formattedName = companyName.Replace(" ", "-");

        formattedName = System.Text.RegularExpressions.Regex.Replace(formattedName, "-{2,}", "-");

        NavigationManager.NavigateTo($"/loja/{formattedName}", false);
    }
}