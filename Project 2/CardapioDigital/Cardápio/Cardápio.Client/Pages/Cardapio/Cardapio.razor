@using Cardápio.Client.Components.Modal
@using Cardápio.Client.Pages.Cardapio.ShoppingCartContext
@page "/loja/{nomeId}"
@implements IDisposable

@using Microsoft.JSInterop

@inject HttpClient HttpClient;
@inject NavigationManager _navigationManager;
@inject IJSRuntime jsRuntime;
@inject ShoppingCartContextService CartService
@inject NavigationManager NavigationManager

@using System.Collections.ObjectModel;
@using System.Net.Http.Json;


<head>
    @* <HeadOutlet /> *@
    @* <PageTitle>@nomeId?.Replace("-", " ") | Disponível no Escolha AI</PageTitle> *@
    <title>@nomeId?.Replace("-", " ") | Disponível no Escolha AI</title>
</head>



@code {
    private string BaseUrl => NavigationManager.BaseUri;

    [CascadingParameter]
    public bool isCollapsed { get; set; }
    [Parameter]
    public string nomeId { get; set; } = "";

    private int decryptedID = 0;
    private EmpresaGetDTO empresa = new();
    private ObservableCollection<ProdutoGetDTO> produtos = new();
    private ObservableCollection<CategoriaGetDTO> categorias = new();
    private string token = "";
    private string searchTerm = string.Empty;
    private List<CartModel> cartItems = new();
    private bool isCartOpen = false;
    private object? cartComponent;
    private int totalCartItems = 0;
    private decimal totalCartValue = 0;

    // Evento para receber mudanças de estado do carrinho

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Inscrever-se no evento de atualização do carrinho
            CartService.OnCartUpdated += OnCartUpdatedHandler;
            
            // token = await Provider.GetTokenAsyncIsNotRequired();
            await GetDataCompany();
            await GetDataProduct();
            await GetDataCategory();

            StateHasChanged();

            // Inicializar Splide para produtos em destaque se houver
            if (produtos != null && produtos.Any(p => p.Destaque))
            {
                await jsRuntime.InvokeVoidAsync("initializeSplideHighlight");
            }
            
            // await jsRuntime.InvokeVoidAsync("initializeSplide");
            await jsRuntime.InvokeVoidAsync("setupScrollListener");
            await Task.Yield();
        }

        await base.OnAfterRenderAsync(firstRender);
    }

    private async void OnCartUpdatedHandler()
    {
        cartItems = await CartService.GetCartItemsAsync();
        totalCartItems = CartService.TotalItems;
        totalCartValue = await CartService.GetTotalValueAsync();
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        CartService.OnCartUpdated -= OnCartUpdatedHandler;
    }

    private string FormatarPreco(decimal? preco) => preco.HasValue ? $"R$ {preco.Value:F2}" : "Preço indisponível";

    private IEnumerable<ProdutoGetDTO> FiltrarProdutos()
    {
        if (produtos == null || !produtos.Any())
        {
            return Enumerable.Empty<ProdutoGetDTO>();
        }

        if (string.IsNullOrWhiteSpace(searchTerm))
        {
            return produtos;
        }

        var filtered = produtos.Where(p => p.Nome != null && p.Nome.Contains(searchTerm, StringComparison.OrdinalIgnoreCase));
        return filtered;
    }

    private async void OnSearchTermChanged(ChangeEventArgs e)
    {
        searchTerm = e.Value?.ToString() ?? string.Empty;
        await Task.Delay(50);
        if (produtos != null && produtos.Count() > 0 && produtos.Any(p => p.Destaque))
        {
            await jsRuntime.InvokeVoidAsync("initializeSplideHighlight");
            await Task.Yield();
        }
        StateHasChanged();
    }

    async Task GetDataCompany()
    {
        try
        {
            var result = await HttpClient.GetFromJsonAsync<EmpresaGetDTO>("/api/enterprise/GetEnterpriseByName/" + nomeId.Replace("-", " "));
            empresa = result ?? new EmpresaGetDTO();
            
            // Garantir que as propriedades não sejam null
            if (empresa != null)
            {
                empresa.Nome = empresa.Nome ?? "";
                empresa.ImageLogo = empresa.ImageLogo ?? "";
                empresa.ImageBanner = empresa.ImageBanner ?? "";
            }
        }
        catch (Exception ex)
        {
            empresa = new EmpresaGetDTO();
        }
        finally
        {
            StateHasChanged();
        }
    }

    async Task GetDataProduct()
    {
        try
        {
            var result = await HttpClient.GetFromJsonAsync<ObservableCollection<ProdutoGetDTO>>("/api/product/GetProductsByCompanyNamePublic/" + nomeId.Replace("-", " "));
            produtos = result ?? new ObservableCollection<ProdutoGetDTO>();
            foreach (var prod in produtos.Take(3))
            {
                Console.WriteLine($"[DEBUG] Produto: {prod.Nome} (CategoriaID: {prod.CategoriaID})");
            }
        }
        catch (Exception ex)
        {
            produtos = new ObservableCollection<ProdutoGetDTO>();
        }
        finally
        {
            StateHasChanged();
        }
    }

    async Task GetDataCategory()
    {
        try
        {
            var result = await HttpClient.GetFromJsonAsync<ObservableCollection<CategoriaGetDTO>>("/api/category/GetCategoriesByCompanyName/" + nomeId.Replace("-", " "));
            categorias = result ?? new ObservableCollection<CategoriaGetDTO>();
            foreach (var cat in categorias)
            {
                Console.WriteLine($"[DEBUG] Categoria: {cat.Nome} (ID: {cat.ID})");
            }
        }
        catch (Exception ex)
        {
            categorias = new ObservableCollection<CategoriaGetDTO>();
        }
        finally
        {
            StateHasChanged();
        }
    }

    private async Task ScrollToCategory(int categoriaId)
    {
        await jsRuntime.InvokeVoidAsync("scrollToElement", $"categoria-{categoriaId}");
        await Task.Yield();
    }

    private string HexToRgbA(string hex, double alpha)
    {
        hex = hex.TrimStart('#');

        int r = Convert.ToInt32(hex.Substring(0, 2), 16);
        int g = Convert.ToInt32(hex.Substring(2, 2), 16);
        int b = Convert.ToInt32(hex.Substring(4, 2), 16);

        return $"rgba({r}, {g}, {b}, {alpha.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)});";
    }

    private ProdutoGetDTO? selectedProduct;

    private bool isViewMenuProductModalOpen;
    private bool isViewCartProductModalOpen;

    private void OpenViewProductModal(ProdutoGetDTO product)
    {
        selectedProduct = product;
        isViewMenuProductModalOpen = true;
        StateHasChanged(); // Força atualização para esconder menu
    }

    private Task OnViewProductClose()
    {
        Task.Yield();

        selectedProduct = null;
        isViewMenuProductModalOpen = false;
        isViewCartProductModalOpen = false;

        StateHasChanged(); // Força atualização para mostrar menu novamente

        return Task.CompletedTask;
    }

    // Restaurado cartComponent 
    private async Task OpenCart()
    {
        if (cartComponent != null)
        {
            await ((dynamic)cartComponent).OpenCart();
        }
    }

    private async Task AddItemToCart(CartModel cartItem)
    {
        try 
        {
            
            await CartService.AddToCartAsync(cartItem);
            
            cartItems = await CartService.GetCartItemsAsync();
            
            // Fechar o modal do produto
            selectedProduct = null;
            isViewMenuProductModalOpen = false;
            
            // Abrir o modal do carrinho
            if (cartComponent != null)
            {
                await ((dynamic)cartComponent).OpenCart();
            }
            else
            {
                Console.WriteLine($"[Cardapio] ERROR: cartComponent é null!");
            }
            
            StateHasChanged(); // Força atualização do estado dos modais
       }
        catch (Exception ex)
        {
            Console.WriteLine($"[Cardapio] Stack trace: {ex.StackTrace}");
        }
    }

    private void EditItemCart(CartModel item)
    {
        var produtoParaEditar = produtos.FirstOrDefault(p => p.ID == item.Id);
        if (produtoParaEditar != null)
        {
            selectedProduct = produtoParaEditar;
            selectedProduct.CartItem = item;
            isViewCartProductModalOpen = true;
            StateHasChanged(); // Força atualização para esconder menu
        }
    }


    // private ShoppingCartContext.ShoppingCartContext cartComponent;

    private CartModel ConvertToCartModel(ProdutoGetDTO produto)
    {
        // Determina o preço a ser usado (promocional se disponível, senão o preço normal)
        decimal precoFinal = produto.Promocao && produto.PrecoPromocional.HasValue 
            ? produto.PrecoPromocional.Value 
            : produto.Preco ?? 0;

        return new CartModel
        {
            Id = produto.ID,
            Name = produto.Nome ?? string.Empty,
            ImageUrl = produto.ImagemThumbnail ?? string.Empty,
            Price = precoFinal,
            Observation = string.Empty,
            // Adicione outros campos necessários
        };
    }

    private async Task FinalizarPedidoWhatsapp()
    {
        cartItems = await CartService.GetCartItemsAsync();
        if (empresa == null || string.IsNullOrWhiteSpace(empresa.Telefone))
        {
            await jsRuntime.InvokeVoidAsync("alert", "Telefone da empresa não configurado!");
            return;
        }
        var telefone = empresa.Telefone.Replace("(", "").Replace(")", "").Replace("-", "").Replace(" ", "");
        if (!telefone.StartsWith("55")) telefone = "55" + telefone;
        var texto = $"Pedido EscolhaAI%0A%0A";
        
        decimal totalOriginal = 0;
        decimal totalFinal = 0;
        bool temPromocao = false;
        
        foreach (var item in cartItems)
        {
            // Busca o produto original para verificar se é promocional
            var produto = produtos.FirstOrDefault(p => p.ID == item.Id);
            
            if (produto?.Promocao == true && produto.PrecoPromocional.HasValue)
            {
                temPromocao = true;
                var precoOriginalProduto = produto.Preco ?? 0;
                var precoPromocionalProduto = produto.PrecoPromocional.Value;
                
                texto += $"- {item.Name}%0A";
                texto += $"  🔥 PROMOÇÃO: R$ {precoPromocionalProduto:F2} (era R$ {precoOriginalProduto:F2})%0A";
                
                totalOriginal += precoOriginalProduto * item.Quantity;
                totalFinal += precoPromocionalProduto * item.Quantity;
            }
            else
            {
                texto += $"- {item.Name} (R$ {item.Price:F2})%0A";
                totalOriginal += item.Price * item.Quantity;
                totalFinal += item.Price * item.Quantity;
            }
        }
        
        texto += "%0A";
        
        if (temPromocao)
        {
            var economia = totalOriginal - totalFinal;
            texto += $"💰 Total original: R$ {totalOriginal:F2}%0A";
            texto += $"🎉 Total com promoção: R$ {totalFinal:F2}%0A";
            texto += $"💵 Você economizou: R$ {economia:F2}%0A";
        }
        else
        {
            texto += $"Total: R$ {totalFinal:F2}%0A";
        }
        
        var url = $"https://wa.me/{telefone}?text={texto}";
        await jsRuntime.InvokeVoidAsync("open", url, "_blank");
    }
}

<Modal T="CartModel" SelectedDTO="ProdutoGetDTO"
       Selected="selectedProduct"
       IsOpen="isViewMenuProductModalOpen"
       OnConfirm="@((CartModel cartItem) => AddItemToCart(cartItem))"
       OnCancel="@(() => OnViewProductClose())"
       ActionType="view-menu/produto" />

<header class="header @(token != null ? "header-nav-responsive" : "")">
    <nav class="header-nav @(token != null && isCollapsed ? "collapse" : "")" style="@(token == null ? "padding-left: 2.3rem; padding-right: 2.3rem;" : "")">
        <div class="container-header">
            <div class="logo-header">
                @if (empresa == null || empresa.Nome == null || empresa.ImageLogo == null)
                {
                    <div class="skeleton skeleton-logo-header"></div>
                    <div class="skeleton skeleton-text-header" style="width: 150px;"></div>
                }
                else
                {
                    <div class="img" style="background-image: url('@(BaseUrl + "imagens/logo/" + empresa.ImageLogo)');"></div>
                    <h1>@empresa.Nome</h1>
                }
            </div>
            <div class="cart-shopping" @onclick="OpenCart">
                <div class="notification number">@totalCartItems</div>
                <i class="fa-solid fa-cart-shopping cart" style="color: #ffffff;"></i>
            </div>
        </div>
    </nav>
</header>

<div class="navigation @(token != null ? "navigation-responsive" : "") @(token != null && isCollapsed ? "collapse" : "")" 
     id="categoryMenu" 
     style="@(token == null ? "margin-left: 0 !important;" : "margin-left: 4rem;") display: none; opacity: 0; transition: opacity 0.3s ease-in-out;">
    <!-- Versão simples sem Splide para testar -->
    <div style="display: flex; justify-content: center; align-items: center; gap: 10px; flex-wrap: wrap; padding: 10px;">
        @if (categorias != null && categorias.Any())
        {
            foreach (var categoria in categorias)
            {
                var produtosFiltrados = FiltrarProdutos().Where(p => p.CategoriaID == categoria.ID).ToList();

                <button class="option button-blue" style="background-color: transparent !important; cursor: pointer; border: 1px solid #ccc; padding: 8px 12px; border-radius: 4px;" @onclick="() => ScrollToCategory(categoria.ID)" data-category-id="@categoria.ID">
                    @categoria.Nome (@produtosFiltrados.Count)
                </button>
            }
        }
        else
        {
            <p style="text-align: center; color: #666;">Carregando categorias...</p>
        }
    </div>
    
    <!-- Versão original com Splide (comentada) -->
    @* <div class="splide" id="categorySplide" style="display: none;">
