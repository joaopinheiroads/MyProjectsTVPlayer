<script type="text/javascript">
    let scrollTimeout;
    let isScrolling = false;
    let hasScrolled = false;

    function setupScrollListener() {
        const categoryMenu = document.getElementById('categoryMenu');
        
        console.log('setupScrollListener chamado');
        console.log('categoryMenu:', categoryMenu);

        if (categoryMenu) {
            // Inicialmente oculto
            categoryMenu.style.display = 'none';
            categoryMenu.style.opacity = '0';

            // Listener para detectar scroll
            window.addEventListener('scroll', function () {
                const scrollPosition = window.scrollY;
                
                // Só mostra o menu se o usuário fez scroll para baixo
                if (scrollPosition > 100 && !hasScrolled) {
                    hasScrolled = true;
                    showCategoryMenu();
                } else if (scrollPosition > 100) {
                    // Se já scrollou antes, apenas redefine o timeout
                    resetHideTimeout();
                }
                
                // Se voltar ao topo, oculta o menu
                if (scrollPosition <= 100) {
                    hasScrolled = false;
                    hideCategoryMenu();
                }
            });
        }
    }

    function showCategoryMenu() {
        const categoryMenu = document.getElementById('categoryMenu');
        if (categoryMenu) {
            categoryMenu.style.display = 'flex';
            // Pequeno delay para permitir que o display seja aplicado antes da transição
            setTimeout(() => {
                categoryMenu.style.opacity = '1';
            }, 10);
            
            resetHideTimeout();
        }
    }

    function hideCategoryMenu() {
        const categoryMenu = document.getElementById('categoryMenu');
        if (categoryMenu) {
            categoryMenu.style.opacity = '0';
            // Aguarda a transição terminar antes de ocultar completamente
            setTimeout(() => {
                if (categoryMenu.style.opacity === '0') {
                    categoryMenu.style.display = 'none';
                }
            }, 300);
        }
        
        // Limpa o timeout se existir
        if (scrollTimeout) {
            clearTimeout(scrollTimeout);
            scrollTimeout = null;
        }
    }

    function resetHideTimeout() {
        // Limpa o timeout anterior se existir
        if (scrollTimeout) {
            clearTimeout(scrollTimeout);
        }
        
        // Define um novo timeout de 3 segundos
        scrollTimeout = setTimeout(() => {
            hideCategoryMenu();
        }, 3000);
    }

    function scrollToElement(elementId) {
        const element = document.getElementById(elementId);
        if (element) {
            element.scrollIntoView({
                behavior: 'smooth',
                block: 'start'
            });
            
            // Resetar o timeout de ocultação ao navegar
            resetHideTimeout();
        } else {
            console.log('Elemento não encontrado:', elementId);
        }
    }
</script>

