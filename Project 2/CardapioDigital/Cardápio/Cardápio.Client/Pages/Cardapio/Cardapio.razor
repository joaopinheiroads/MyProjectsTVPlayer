<div class="container @(isCollapsed ? "collapse" : "") @(token == null ? "out-system" : "system")" style="@(token == null ? "padding-left: 2.3rem; padding-right: 2.3rem;" : "")">
    <div class="banner">
        @if (empresa == null || empresa.Nome == null || empresa.ImageBanner == null)
        {
            <div class="skeleton skeleton-banner"></div>
        }
        else
        {
            <div class="img" style="background-image: url('@(BaseUrl + "imagens/banner/" + empresa.ImageBanner)');"></div>
        }
    </div>

    <div class="logo">
        @if (empresa == null || empresa.Nome == null || empresa.ImageLogo == null)
        {
            <div class="skeleton skeleton-logo"></div>
            <div class="skeleton skeleton-text" style="width: 150px;"></div>
        }
        else
        {
            <div class="img" style="background-image: url('@(BaseUrl + "imagens/logo/" + empresa.ImageLogo)');"></div>
            <h1>@empresa.Nome</h1>
        }
    </div>

    @if (produtos == null)
    {
        <div class="container-destaque">
            <div class="skeleton-container">
                @for (int i = 0; i < 3; i++)
                {
                    <div class="skeleton skeleton-card"></div>
                }
            </div>
        </div>
    }

    <div class="search-container">
        <i class="fa-solid fa-magnifying-glass search-icon"></i>
        <input type="text" class="search-input" id="searchInput" placeholder="Pesquisar no cardápio" @oninput="OnSearchTermChanged">
    </div>

    @if (produtos != null && produtos.Count() > 0)
    {
        var produtosDestaque = FiltrarProdutos().Where(p => p.Destaque).ToList();

        if (produtosDestaque.Any())
        {
            <div class="container-destaque">
                <h3>Destaques</h3>
                <div class="carrosel splide" id="highlightSplide">
                    <div class="splide__track">
                        <div class="splide__list">
                            @foreach (var produto in produtosDestaque)
                            {
                                <div class="splide__slide card" @onclick="() => OpenViewProductModal(produto)">
                                    <div class="container-image">
                                        <div class="image" style="background-image: url('/imagens/ThumbnailProducts/@produto.ImagemThumbnail');"></div>
                                    </div>
                                    <div class="container-details">
                                        <div class="details">
                                            <div class="container-badge">
                                                <h5 class="category">@produto.Categoria</h5>
                                                <h5 class="favorite">Produto destaque</h5>
                                            </div>
                                            <div class="container-title">
                                                <h4 class="title">@produto.Nome</h4>
                                            </div>
                                            <div class="container-descript">
                                                <p class="Descript">@produto.Descricao</p>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    }

    @if (categorias == null)
    {
        <div class="skeleton-categories">
            @for (int i = 0; i < 2; i++)
            {
                <div class="skeleton-category">
                    <div class="skeleton-category-title">
                        <div class="skeleton-line-one"></div>
                        <div class="skeleton-title"></div>
                        <div class="skeleton-line-two"></div>
                    </div>
                    <div class="skeleton-cards">
                        @for (int j = 0; j < 2; j++)
                        {
                            <div class="skeleton-card-product"></div>
                        }
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        @foreach (var categoria in categorias)
        {
            var produtosFiltrados = FiltrarProdutos().Where(p => p.CategoriaID == categoria.ID).ToList();

            if (produtosFiltrados.Any())
            {
                <div class="container-categoria" id="categoria-@categoria.ID">
                    <div class="category-title">
                        <span class="line-one" style="background-color: @HexToRgbA(categoria.BackgroundColor, 0.6);"></span>
                        <h3>@categoria.Nome</h3>
                        <span class="line-two" style="background-color: @HexToRgbA(categoria.BackgroundColor, 0.6);"></span>
                    </div>
                    <div class="container-cards">
                        @foreach (var produto in produtosFiltrados)
                        {
                            <div class="card-product" @onclick="() => OpenViewProductModal(produto)">
                                <div class="product-image">
                                    <div class="image" style="background-image: url('/imagens/ThumbnailProducts/@produto.ImagemThumbnail');"></div>
                                </div>
                                <div class="product-details">
                                    <div class="details">
                                        <div class="container-badge">
                                            @if (produto.Destaque)
                                            {
                                                <h5 class="favorite">Produto destaque</h5>
                                            }
                                        </div>
                                        <div class="container-title-product">
                                            <h4 class="title">@produto.Nome</h4>
                                        </div>
                                        <div class="container-descript">
                                            <p class="Descript">@produto.Descricao</p>
                                        </div>
                                    </div>
                                    <div class="price">
                                        @if (produto.Promocao && produto.PrecoPromocional.HasValue)
                                        {
                                            <span class="number" style="color: #1db954; font-weight: bold;">@FormatarPreco(produto.PrecoPromocional)</span>
                                            <span class="number" style="text-decoration: line-through; color: #888; margin-left: 8px;">@FormatarPreco(produto.Preco)</span>
                                        }
                                        else
                                        {
                                            <span class="number">@FormatarPreco(produto.Preco)</span>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        }
    }
</div>

<div class="footer-cart-shopping" @onclick="OpenCart">
    <div class="container-footer">
        <div class="cart-shopping-footer" >
            <div class="notification number">@totalCartItems</div>
            <i class="fa-solid fa-cart-shopping cart" style="color: #ffffff;"></i>
        </div>
        <div>
            <span class="number">@FormatarPreco(totalCartValue)</span>
        </div>
    </div>
</div>

