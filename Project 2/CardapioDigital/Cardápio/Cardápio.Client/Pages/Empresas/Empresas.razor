
@page "/empresas"
@layout Cardápio.Client.Components.Layout.SystemLayout

@using System.Net.Http
@using System.Net.Http.Json
@using System.Collections.ObjectModel
@using Microsoft.JSInterop
@using Radzen
@using Radzen.Blazor
@using Cardápio.Client.Dto
@using Cardápio.Client.Components.Modal
@using Cardápio.Client.Components.CopyButton
@using Cardápio.Client.Components.Layout
@using Cardápio.Client.Components.SpinnerLoader
@using Microsoft.AspNetCore.Components.Web

@using Microsoft.AspNetCore.Components

@inject HttpClient HttpClient
@inject IJSRuntime jsRuntime
@inject Cardápio.Client.Infra.Provider.CustomAuthenticationStateProvider Provider
@inject Cardápio.Client.Pages.Empresas.EmpresaService EmpresaService


<head>
    <HeadOutlet />
    <PageTitle>Gerenciar empresas | Escolha AI</PageTitle>
</head>

<style type="text/css">
    @@media screen and (max-width:770px) {
        .copy {
            display: none !important
        }
    } 

    .rz-column-title-content {
        font-weight: bold !important;
    }

    .rz-column-title {
        font-weight: bold !important;
    }

    @@media screen and (max-width:768px) {
        .hidden {
            display: none !important;
        }

        tbody {
            display: grid !important;
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media screen and (max-width:600px) {
        .hidden {
            display: none !important;
        }

        tbody {
            display: grid !important;
            grid-template-columns: repeat(1, 1fr);
        }
    }

    .wrap {
        gap: .5rem !important;
    }
</style>

<Modal T="EmpresaAddDTO"
       IsOpen="isCreatingCompanyModalOpen"
       OnConfirm="@OnCreateCompanyConfirm"
       OnCancel="@OnCreateCompanyCancel"
       ActionType="creating/empresa"
       SelectedDTO="object">
</Modal>

<Modal T="EmpresaAddDTO"
       IsOpen="isEditingCompanyModalOpen"
       OnConfirm="@OnEditCompanyConfirm"
       OnCancel="@OnEditCompanyCancel"
       ActionType="editing/empresa"
       SelectedDTO="EmpresaGetDTO"
       Selected="selectedEmpresa">
</Modal>

<Modal T="object"
       IsOpen="isDeletingCompanyModalOpen"
       OnConfirm="@OnDeleteCompanyConfirm"
       OnCancel="@OnDeleteCompanyCancel"
       ActionType="deleting/empresa"
       SelectedDTO="object">
</Modal>

<Modal T="object"
       IsOpen="isViewCompanyModalOpen"
       OnConfirm="() => {}"
       OnCancel="@OnViewCompanyClose"
       ActionType="view/company"
       SelectedDTO="EmpresaGetDTO"
       Selected="selectedEmpresa">
</Modal>
<div class="container-title">
    <i class="fa-solid fa-building"></i>
    <h3 class="title-page-section">Empresas</h3>
</div>
<div class="container-section">
    @if (isLoading)
    {
        <div class="container">
            <SpinnerLoader PrimaryColor="#272A2D" SecondaryColor="#ffffff" Size="90" />
        </div>
    }

    @if (!isLoading)
    {
        <div class="container-group">
            <div>
                <input @oninput="FilterChanged" placeholder="Filtrar empresas..." class="input" style="width: 300px;" />
            </div>
            <div class="button-container">
                <button class="rz-ripple button-green" @onclick="OpenCreatingCompanyModal"><i class="fa-solid fa-plus"></i> Registrar empresa</button>
            </div>
        </div>
        <RadzenDataGrid @ref="dataGrid" AllowFiltering="true" AllowColumnResize="true" AllowAlternatingRows="true" AllowSorting="true" PageSize="12" AllowPaging="true"
                        PagerHorizontalAlign="HorizontalAlign.Left" FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive" ShowPagingSummary="true" Data="@filteredEmpresas"
                        SelectionMode="DataGridSelectionMode.Single" class="rz-border-radius-1 rz-shadow-1" Page="@(() => {})"
                        style="min-height: 600px; max-height: 600px; height: 100%;" HeaderStyle="font-weight: bold;" Responsive="true">
            <EmptyTemplate>
                <p style="color: lightgrey; font-size: 24px; text-align: center; margin: 2rem;">Nenhuma empresa foi encontrada.</p>
            </EmptyTemplate>
            <Columns>
                <RadzenDataGridColumn TItem="EmpresaGetDTO" Property="Nome" Title="Nome" Resizable="true" Filterable="false" Sortable="true" MinWidth="200px">
                    <Template Context="context">
                        <div style="overflow-x: auto; max-height: 100px; white-space: nowrap; box-sizing: border-box; padding-right: 16px; width: 100%;">
                            <CopyButton Content="@context.Nome" Title="Copiar Nome" />
                        </div>
                    </Template>
                </RadzenDataGridColumn>

                <RadzenDataGridColumn TItem="EmpresaGetDTO" Property="RazaoSocial" Title="Razão Social" Resizable="true" Filterable="false" Sortable="true" MinWidth="200px">
                    <Template Context="context">
                        <div style="overflow-x: auto; max-height: 100px; white-space: nowrap; box-sizing: border-box; padding-right: 16px; width: 100%;">
                            @context.RazaoSocial
                        </div>
                    </Template>
                </RadzenDataGridColumn>

                <RadzenDataGridColumn TItem="EmpresaGetDTO" Property="CNPJ" Title="CNPJ" Filterable="false" Resizable="true" Sortable="false" CssClass="number" MinWidth="50px">
                    <Template Context="context">
                        <div style="overflow-x: auto; max-height: 100px; white-space: nowrap; box-sizing: border-box; padding-right: 16px; width: 100%;">
                            <CopyButton Content="@context.CNPJ" Title="Copiar CNPJ" />
                        </div>
                    </Template>
                </RadzenDataGridColumn>

                <RadzenDataGridColumn TItem="EmpresaGetDTO" Property="Telefone" Title="Telefone" Filterable="false" Resizable="true" Sortable="false" CssClass="number" MinWidth="50px">
                    <Template Context="context">
                        <div style="overflow-x: auto; max-height: 100px; white-space: nowrap; box-sizing: border-box; padding-right: 16px; width: 100%;">
                            <CopyButton Content="@context.Telefone" Title="Copiar Telefone" />
                        </div>
                    </Template>
                </RadzenDataGridColumn>

                <RadzenDataGridColumn TItem="EmpresaGetDTO" Property="EstadoID" Title="Estado" Filterable="false" Resizable="true" Sortable="true" MinWidth="50px">
                    <Template Context="context">
                        <div style="overflow-x: auto; max-height: 100px; white-space: nowrap; box-sizing: border-box; padding-right: 16px; width: 100%;">
                            @context.EstadoID
                        </div>
                    </Template>
                </RadzenDataGridColumn>

                <RadzenDataGridColumn TItem="EmpresaGetDTO" Property="Buttons" Filterable="false" Sortable="false" Width="200px" Resizable="false" Frozen="true" FrozenPosition="FrozenColumnPosition.Right">
                    <Template Context="context">
                        <div class="wrap">
                            <button class="view-button rz-ripple button-cyan" @onclick="() => OpenViewCompanyModal(context)"><i class="fa-regular fa-eye"></i></button>
                            <button class="edit-button rz-ripple button-blue" @onclick="() => OpenEditingCompanyModal(context)"><i class="fa-regular fa-pen-to-square"></i></button>
                            @if (usuario != null && usuario.EmpresaID != context.ID)
                            {
                                <button class="trash-button rz-ripple" @onclick="() => OpenDeletingCompanyModal(context)"><i class="fa-regular fa-trash-can"></i></button>
                            }
                        </div>
                    </Template>
                </RadzenDataGridColumn>
            </Columns>
        </RadzenDataGrid>
    }
</div>

@code {
    private EmpresaGetDTO? draggedItem;

    private bool isLoading = true;
    private string searchTerm = string.Empty;
    private ObservableCollection<EmpresaGetDTO> filteredEmpresas = new ObservableCollection<EmpresaGetDTO>();
    private ObservableCollection<EmpresaGetDTO> empresas = new ObservableCollection<EmpresaGetDTO>();
    private RadzenDataGrid<EmpresaGetDTO>? dataGrid;
    private UsuarioGetDTO? usuario;
    string? token;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            token = await Provider.GetTokenAsync();
            //await GetUser();
            usuario = Provider.UsuarioOwner;
            await GetData();
        }
    }

    async Task GetUser()
    {
        HttpClient.DefaultRequestHeaders.Authorization =
            new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);

        var result = await HttpClient.GetFromJsonAsync<UsuarioGetDTO>("/api/authentication/getCompanyID");
        usuario = result;
    }

    async Task GetData()
    {
        try
        {
            List<EmpresaGetDTO> result = await EmpresaService.GetData();
            empresas = new ObservableCollection<EmpresaGetDTO>(result);

            ApplyFilter();
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private void FilterChanged(ChangeEventArgs e)
    {
        searchTerm = e.Value.ToString();
        ApplyFilter();
    }

    private void ApplyFilter()
    {
        filteredEmpresas = new ObservableCollection<EmpresaGetDTO>(empresas
            .Where(c => string.IsNullOrEmpty(searchTerm) || c.Nome.Contains(searchTerm, StringComparison.OrdinalIgnoreCase))
            .ToList());

        StateHasChanged();
    }
}

@code {
    private bool isEditingCompanyModalOpen;
    private bool isCreatingCompanyModalOpen;
    private bool isDeletingCompanyModalOpen;
    private bool isViewCompanyModalOpen;

    private EmpresaGetDTO? selectedEmpresa;

    private void OpenCreatingCompanyModal()
    {
        isCreatingCompanyModalOpen = true;
    }

    private async Task OnCreateCompanyConfirm(EmpresaAddDTO companyTransferDataDTO)
    {
        try
        {
            HttpClient.DefaultRequestHeaders.Authorization =
                new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
            VerifyCompanyDTO generatedVerifyModel = GenerateVerifyModel(companyTransferDataDTO.Nome, companyTransferDataDTO.RazaoSocial, companyTransferDataDTO.CNPJ, null);
            HttpResponseMessage verifyCompanyAlreadyExists = await HttpClient.PostAsJsonAsync("api/enterprise/VerifyCompanyAlreadyExists", generatedVerifyModel);

            if (!verifyCompanyAlreadyExists.IsSuccessStatusCode)
            {
                string errorResponse = await verifyCompanyAlreadyExists.Content.ReadAsStringAsync();
                throw new Exception(errorResponse);
            }

            MultipartFormDataContent formData = new MultipartFormDataContent();

            if (companyTransferDataDTO.Files.selectedBanner != null)
            {
                companyTransferDataDTO.Files.selectedBanner.Position = 0;
                formData.Add(new StreamContent(companyTransferDataDTO.Files.selectedBanner), "banner", "banner.jpg");
            }

            if (companyTransferDataDTO.Files.selectedLogo != null)
            {
                companyTransferDataDTO.Files.selectedLogo.Position = 0;
                formData.Add(new StreamContent(companyTransferDataDTO.Files.selectedLogo), "logo", "logo.jpg");
            }

            UploadResponseEmpresa result = null;

            if (companyTransferDataDTO.Files.selectedBanner != null || companyTransferDataDTO.Files.selectedLogo != null)
            {
                HttpClient.DefaultRequestHeaders.Authorization =
                    new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);

                HttpResponseMessage response = await HttpClient.PostAsync("/api/enterprise/SaveCompanyImages", formData);

                string jsonResponse = await response.Content.ReadAsStringAsync();
                result = System.Text.Json.JsonSerializer.Deserialize<UploadResponseEmpresa>(jsonResponse);
            }

            companyTransferDataDTO.ColBannerImagem = EmpresaService.InsertFileBanner(result);
            companyTransferDataDTO.ColLogoImagem = EmpresaService.InsertFileLogo(result);
            companyTransferDataDTO.Files = null;
            companyTransferDataDTO.CEP.Trim();

            await EmpresaService.OnCreateCompanyConfirm(companyTransferDataDTO);
            await GetData();

            isCreatingCompanyModalOpen = false;
        } 
        catch (Exception err)
        {
            throw err;
        }
    }

    private async Task OnCreateCompanyCancel()
    {
        isCreatingCompanyModalOpen = false;
    }

    private void OpenEditingCompanyModal(EmpresaGetDTO empresaGetDTO)
    {
        selectedEmpresa = empresaGetDTO;
        isEditingCompanyModalOpen = true;
    }

    private async Task OnEditCompanyCancel()
    {
        selectedEmpresa = null;
        isEditingCompanyModalOpen = false;
    }

    private async Task OnEditCompanyConfirm(EmpresaAddDTO companyTransferDataDTO)
    {
        try {
            HttpClient.DefaultRequestHeaders.Authorization =
                new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
            VerifyCompanyDTO generatedVerifyModel = GenerateVerifyModel(companyTransferDataDTO.Nome, companyTransferDataDTO.RazaoSocial, companyTransferDataDTO.CNPJ, selectedEmpresa.ID);
            HttpResponseMessage verifyCompanyAlreadyExists = await HttpClient.PostAsJsonAsync("api/enterprise/VerifyCompanyAlreadyExists", generatedVerifyModel);

            if (!verifyCompanyAlreadyExists.IsSuccessStatusCode)
            {
                string errorResponse = await verifyCompanyAlreadyExists.Content.ReadAsStringAsync();
                throw new Exception(errorResponse);
            }

            MultipartFormDataContent formData = new MultipartFormDataContent();

            if (companyTransferDataDTO.Files.selectedBanner != null) {
                companyTransferDataDTO.Files.selectedBanner.Position = 0;
                formData.Add(new StreamContent(companyTransferDataDTO.Files.selectedBanner), "banner", "banner.jpg");
            }

            if (companyTransferDataDTO.Files.selectedLogo != null) {
                companyTransferDataDTO.Files.selectedLogo.Position = 0;
                formData.Add(new StreamContent(companyTransferDataDTO.Files.selectedLogo), "logo", "logo.jpg");
            }

            UploadResponseEmpresa result = null;

            if (companyTransferDataDTO.Files.selectedBanner != null || companyTransferDataDTO.Files.selectedLogo != null) {
                HttpClient.DefaultRequestHeaders.Authorization =
                    new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);

                HttpResponseMessage response = await HttpClient.PostAsync("/api/enterprise/SaveCompanyImages", formData);

                string jsonResponse = await response.Content.ReadAsStringAsync();
                result = System.Text.Json.JsonSerializer.Deserialize<UploadResponseEmpresa>(jsonResponse);
            }

            companyTransferDataDTO.ColBannerImagem = EmpresaService.InsertFileBanner(result);
            companyTransferDataDTO.ColLogoImagem = EmpresaService.InsertFileLogo(result);
            companyTransferDataDTO.Files = null;
            companyTransferDataDTO.CEP.Trim();

            await EmpresaService.OnEditCompanyConfirm(companyTransferDataDTO, selectedEmpresa.ID);
            await GetData();

            isEditingCompanyModalOpen = false;
            selectedEmpresa = null;
        }
        catch (Exception err)
        {
            throw err;
        }
    }

    private void OpenDeletingCompanyModal(EmpresaGetDTO empresaGetDTO)
    {
        selectedEmpresa = empresaGetDTO;
        isDeletingCompanyModalOpen = true;   
    }

    private async Task OnDeleteCompanyConfirm()
    {
        await EmpresaService.OnDeleteCompanyConfirm(selectedEmpresa.ID);
        await GetData();

        selectedEmpresa = null;
        isDeletingCompanyModalOpen = false;
    }

    private async Task OnDeleteCompanyCancel()
    {
        selectedEmpresa = null;
        isDeletingCompanyModalOpen = false;
    }

    private void OpenViewCompanyModal(EmpresaGetDTO empresaGetDTO)
    {
        selectedEmpresa = empresaGetDTO;
        isViewCompanyModalOpen = true;
    }

    private void OnViewCompanyClose()
    {
        isViewCompanyModalOpen = false;
    }
}

@code {
    private VerifyCompanyDTO GenerateVerifyModel(string empresaNome, string razaoSocial, string cnpj, int? id)
    {
        return new VerifyCompanyDTO()
            {
                EmpresaNome = empresaNome,
                RazaoSocial = razaoSocial,
                CNPJ = cnpj,
                ID = id,
            };
    }
}