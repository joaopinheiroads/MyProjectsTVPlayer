@page "/adicionais";
@layout Cardápio.Client.Components.Layout.SystemLayout

@inject HttpClient HttpClient;
@inject IJSRuntime jsRuntime;
@inject NavigationManager NavigationManager;
@inject SelectCompanyService EmpresaService;
@inject AdicionalService AdicionalService;
@inject Cardápio.Client.Infra.Provider.CustomAuthenticationStateProvider Provider;
@inject Cardápio.Client.Infra.Crypto.Crypto Crypto;

@using System.Collections.ObjectModel;
@using System.Net.Http.Json;
@using Cardápio.Client.Components.Modal;
@using Cardápio.Client.Components.SelectCompany;
@using Cardápio.Client.Pages.Cardapio;

@code {
    [Inject] private ModalService ModalService { get; set; }

    private bool isLoading = true;
    private string searchTerm = string.Empty;

    private ObservableCollection<GrupoAdicionalGetDTO> filteredGroups = new ObservableCollection<GrupoAdicionalGetDTO>();
    private ObservableCollection<GrupoAdicionalGetDTO> groups = new ObservableCollection<GrupoAdicionalGetDTO>();
    private GrupoAdicionalGetDTO selectedGroup;
    private RadzenDataGrid<GrupoAdicionalGetDTO> dataGrid;
    private UsuarioGetDTO usuario;
    string token;

    private bool isCreateAdditionalModalOpen;
    private bool isEditAdditionalModalOpen;
    private bool isDeletingAdditionalModalOpen;
    private bool isViewQtdProducts;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            token = await Provider.GetTokenAsync();
            //await GetUser();
            usuario = Provider.UsuarioOwner;
            await GetData();
            await Task.Yield();
        }
    }

    protected async override void OnInitialized()
    {
        EmpresaService.EmpresaChanged += UpdateEmpresa;
        ModalService.OnStateChange += StateHasChanged;
        await Task.Yield();
    }

    private async void UpdateEmpresa()
    {
        isLoading = true;
        await InvokeAsync(StateHasChanged);
        await GetData();
        await Task.Yield();
    }

    public async void Dispose()
    {
        EmpresaService.EmpresaChanged -= UpdateEmpresa;
        ModalService.OnStateChange -= StateHasChanged;

        await Task.Yield();
    }

    async Task GetData()
    {
        try
        {
            List<GrupoAdicionalGetDTO> result = await AdicionalService.GetDataWithProducts(ValidateSelectedCompanyID());
            groups = new ObservableCollection<GrupoAdicionalGetDTO>(result);

            ApplyFilter();
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    async Task GetUser()
    {
        HttpClient.DefaultRequestHeaders.Authorization =
            new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);

        var result = await HttpClient.GetFromJsonAsync<UsuarioGetDTO>("/api/authentication/getCompanyID");
        usuario = result;
    }

    private void FilterChanged(ChangeEventArgs e)
    {
        searchTerm = e.Value.ToString();
        ApplyFilter();
    }

    private void ApplyFilter()
    {
        filteredGroups = new ObservableCollection<GrupoAdicionalGetDTO>(groups
            .Where(c => string.IsNullOrEmpty(searchTerm) || c.Nome.Contains(searchTerm, StringComparison.OrdinalIgnoreCase))
            .ToList());

        StateHasChanged();
    }

    private int ValidateSelectedCompanyID()
    {
        if (usuario != null && EmpresaService.EmpresaSelecionada == 0)
        {
            return usuario.EmpresaID ?? 0;
        }

        return EmpresaService.EmpresaSelecionada;
    }

    private void OpenCreateGroupModal()
    {
        isCreateAdditionalModalOpen = true;
    }

    private void OpenEditingGroupModal(GrupoAdicionalGetDTO grupoAdicional)
    {
        isEditAdditionalModalOpen = true;
        selectedGroup = grupoAdicional;
    }

    private void OpenDeletingGroupModal(GrupoAdicionalGetDTO grupoAdicional)
    {
        isDeletingAdditionalModalOpen = true;
        selectedGroup = grupoAdicional;
    }

    private async Task OnCreateAdditionalConfirm()
    {
        await GetData();
        isCreateAdditionalModalOpen = false;
        StateHasChanged();
    }

    private Task OnCreateAdditionalCancel()
    {
        isCreateAdditionalModalOpen = false;
        return Task.CompletedTask;
    }

    private async Task OnEditAdditionalConfirm()
    {
        await GetData();
        isEditAdditionalModalOpen = false;
        selectedGroup = null;
        StateHasChanged();
    }

    private Task OnEditAdditionalCancel()
    {
        isEditAdditionalModalOpen = false;
        selectedGroup = null;
        ModalService.CloseModal("ConfirmEditAdditional");
        ModalService.CloseModal("EditAdditional");
        Task.Yield();
        StateHasChanged();

        return Task.CompletedTask;
    }

    private async Task OnDeleteProductConfirm()
    {
        try
        {
            await AdicionalService.OnDeleteAdditionalConfirm(selectedGroup.ID, EmpresaService.EmpresaSelecionada);
            await GetData();

            isDeletingAdditionalModalOpen = false;
        }
        catch (Exception err)
        {
            Console.WriteLine(err.Message);
        }
    }

    private Task OnDeleteProductCancel()
    {
        isDeletingAdditionalModalOpen = false;
        selectedGroup = null;
        return Task.CompletedTask;
    }

    private void OpenViewQtdProducts(GrupoAdicionalGetDTO grupoAdicional)
    {
        isViewQtdProducts = true;
        selectedGroup = grupoAdicional;
    }

    private async Task OnViewQtdProductsCancel()
    {
        isViewQtdProducts = false;
        selectedGroup = null;
        await GetData();
    }
}

<Modal T="int"
       SelectedDTO="object"
       IsOpen="isCreateAdditionalModalOpen"
       OnConfirm="@OnCreateAdditionalConfirm"
       OnCancel="@OnCreateAdditionalCancel"
       ActionType="creating/additional">
</Modal>

<Modal T="GrupoAdicionalAddDTO"
       SelectedDTO="GrupoAdicionalGetDTO"
       Selected="selectedGroup"
       IsOpen="isEditAdditionalModalOpen"
       OnConfirm="@OnEditAdditionalConfirm"
       OnCancel="@OnEditAdditionalCancel"
       ActionType="editing/additional">
</Modal>

<Modal T="List<ProdutoGetDTO>"
       IsOpen="@(ModalService.GetModalState("ConfirmEditAdditional")?.IsOpen == true)"
       OnConfirm="@(() => ModalService.GetModalState("ConfirmEditAdditional")?.OnConfirm?.Invoke() ?? Task.CompletedTask)"
       OnCancel="@(() => ModalService.GetModalState("ConfirmEditAdditional")?.OnCancel?.Invoke() ?? Task.CompletedTask)"
       ActionType="confirm/additional"
       Selected="@((List<ProdutoGetDTO>)ModalService.GetModalState("ConfirmEditAdditional")?.EditObject)"
       SelectedDTO="List<ProdutoGetDTO>">
</Modal>

<Modal T="object"
       SelectedDTO="object"
       IsOpen="isDeletingAdditionalModalOpen"
       OnConfirm="@OnDeleteProductConfirm"
       OnCancel="@OnDeleteProductCancel"
       ActionType="deleting/additional">
</Modal>

<Modal T="object"
       SelectedDTO="GrupoAdicionalGetDTO"
       Selected="selectedGroup"
       IsOpen="isViewQtdProducts"
       OnConfirm="() => {}"
       OnCancel="@OnViewQtdProductsCancel"
       ActionType="view/qtdProduct">
</Modal>

<Modal T="object"
       IsOpen="@(ModalService.GetModalState("Desvincule")?.IsOpen == true)"
       OnConfirm="@(() => ModalService.GetModalState("Desvincule")?.OnConfirm?.Invoke() ?? Task.CompletedTask)"
       OnCancel="@(() => ModalService.GetModalState("Desvincule")?.OnCancel?.Invoke() ?? Task.CompletedTask)"
       ActionType="confirm/unlink"
       Selected="@((object)ModalService.GetModalState("Desvincule")?.EditObject)"
       SelectedDTO="object">
</Modal>

<head>
    <HeadOutlet />
    <PageTitle>Gerenciar Adicionais | Escolha AI</PageTitle>
</head>

<div class="header">
    <div class="container-title">
        <i class="fa-solid fa-tags"></i>
        <h3 class="title-page-section">Adicionais</h3>
    </div>
    <Select />
</div>
<div class="container-section">
    @if (isLoading || EmpresaService.IsLoading)
    {
        <div class="container">
            <SpinnerLoader PrimaryColor="#272A2D" SecondaryColor="#ffffff" Size="90" />
        </div>
    }

    @if (!isLoading && !EmpresaService.IsLoading)
    {
        <div class="container-group">
            <div>
                <input @oninput="FilterChanged" placeholder="Filtrar adicionais..." class="input" style="width: 300px;" />
            </div>
            <div class="button-container">
                <button class="rz-ripple button-green" @onclick="OpenCreateGroupModal"><i class="fa-solid fa-plus"></i> Registrar grupo</button>
            </div>
        </div>
        <RadzenDataGrid @ref="dataGrid" AllowFiltering="true" AllowColumnResize="true" AllowAlternatingRows="true" AllowSorting="true" PageSize="12" AllowPaging="true"
                        PagerHorizontalAlign="HorizontalAlign.Left" FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive" ShowPagingSummary="true" Data="@filteredGroups"
                        SelectionMode="DataGridSelectionMode.Single" class="rz-border-radius-1 rz-shadow-1" Page="@(() => {})"
                        style="min-height: 600px; max-height: 600px; height: 100%;" HeaderStyle="font-weight: bold;" Responsive="true">
            <EmptyTemplate>
                <p style="color: lightgrey; font-size: 24px; text-align: center; margin: 2rem;">Nenhum adicional foi encontrado.</p>
            </EmptyTemplate>
            <Columns>
                <RadzenDataGridColumn TItem="GrupoAdicionalGetDTO" Property="Nome" Title="Nome do Grupo" MinWidth="140px" Resizable="true" Filterable="false">
                    <Template Context="group">
                        @group.Nome
                    </Template>
                </RadzenDataGridColumn>

                <RadzenDataGridColumn TItem="GrupoAdicionalGetDTO" Property="TipoNome" Title="Tipo do Grupo" MinWidth="140px" Resizable="true" Filterable="false">
                    <Template Context="group">
                        @group.TipoNome
                    </Template>
                </RadzenDataGridColumn>

                <RadzenDataGridColumn TItem="GrupoAdicionalGetDTO" Property="Minimo" Title="Quantidade Mínima" MinWidth="140px" Resizable="true" Filterable="false">
                    <Template Context="group">
                        @group.Minimo
                    </Template>
                </RadzenDataGridColumn>

                <RadzenDataGridColumn TItem="GrupoAdicionalGetDTO" Property="Maximo" Title="Quantidade Máxima" MinWidth="140px" Resizable="true" Filterable="false">
                    <Template Context="group">
                        @group.Maximo
                    </Template>
                </RadzenDataGridColumn>

                <RadzenDataGridColumn TItem="GrupoAdicionalGetDTO" Property="ColProducts" Title="Qtd. Produtos usando" MinWidth="100px" Resizable="true" Filterable="false">
                    <Template Context="group">
                        <button class="products-qtd" @onclick="() => OpenViewQtdProducts(group)">@group.ColProducts?.Count() <i class="fa-solid fa-boxes-stacked"></i></button>
                    </Template>
                </RadzenDataGridColumn>

                <RadzenDataGridColumn TItem="GrupoAdicionalGetDTO" Property="Buttons:" Filterable="false" Sortable="false" Width="140px" Resizable="false" Frozen="true" FrozenPosition="FrozenColumnPosition.Right">
                    <Template>
                        <div class="wrap">
                            <button class="edit-button rz-ripple button-blue" @onclick="() => OpenEditingGroupModal(context)"><i class="fa-regular fa-pen-to-square"></i></button>
                            <button class="trash-button rz-ripple button-pink" @onclick="() => OpenDeletingGroupModal(context)"><i class="fa-regular fa-trash-can"></i></button>
                        </div>
                    </Template>
                </RadzenDataGridColumn>
            </Columns>

            <Template Context="group">
                <RadzenDataGrid AllowFiltering="true" AllowPaging="true" AllowSorting="true" Data="@group.ColGrupoAdicionalItem" TItem="GrupoAdicionalItemGetDTO">
                    <Columns>
                        <RadzenDataGridColumn TItem="GrupoAdicionalItemGetDTO" Property="foto" Filterable="false" Sortable="false" Width="140px" Resizable="false" Frozen="true" FrozenPosition="FrozenColumnPosition.Right">
                            <Template Context="item">
                                <div class="image-additional" style="background-image: url('@($"/imagens/ImageAdditional/{item.ColGrupoAdicionalItemImagem.Arquivo}")')">
                                    
                                </div>
                            </Template>
                        </RadzenDataGridColumn>

                        <RadzenDataGridColumn TItem="GrupoAdicionalItemGetDTO" Property="Nome" Title="Nome do Item" MinWidth="150px" Width="200px" Resizable="true" Filterable="false">
                            <Template Context="item">
                                @item.Nome
                            </Template>
                        </RadzenDataGridColumn>

                        <RadzenDataGridColumn TItem="GrupoAdicionalItemGetDTO" Property="Preco" Title="Preço" MinWidth="100px" Width="150px" Resizable="true" Filterable="false">
                            <Template Context="item">
                                @String.Format(new System.Globalization.CultureInfo("pt-BR"), "{0:C}", item.Preco)
                            </Template>
                        </RadzenDataGridColumn>
                    </Columns>
                </RadzenDataGrid>
            </Template>
        </RadzenDataGrid>
    }
</div>

<style type="text/css">
    .rz-colorpicker-popup {
        z-index: 100000 !important;
    }

    .rz-popup {
        z-index: 100000 !important;
    }

    .rz-column-title-content {
        font-weight: bold !important;
    }

    .rz-column-title {
        font-weight: bold !important;
    }

    .rz-dropdown {
        font-size: 14px !important;
        display: flex;
        justify-content: center;
    }

    @@media screen and (max-width:768px) {
        .hidden {
            display: none !important;
        }

        tbody {
            display: grid !important;
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media screen and (max-width:600px) {
        .hidden {
            display: none !important;
        }

        tbody {
            display: grid !important;
            grid-template-columns: repeat(1, 1fr);
        }
    }

    .global-select {
        align-items: end !important;
    }

    @@media screen and (max-width: 600px) {
        .global-select {
            width: 100%;
        }
    }

    .wrap {
        gap: .5rem !important;
    }
</style>