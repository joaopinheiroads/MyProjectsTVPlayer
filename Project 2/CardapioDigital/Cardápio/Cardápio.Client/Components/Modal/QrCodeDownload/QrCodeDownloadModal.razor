@typeparam T
@typeparam SelectedDTOParam

@inject IJSRuntime JSRuntime;
@inject QrCodeLayoutService QrCodeLayoutService;
@inject SelectCompanyService EmpresaService;
@inject HttpClient HttpClient;
@inject Cardápio.Client.Infra.Provider.CustomAuthenticationStateProvider Provider;

@using System.Collections.ObjectModel
@using Cardápio.Client.Components.Modal;

@code {
    [Inject] private ModalService ModalService { get; set; }

    [Parameter] public string ActionType { get; set; }
    [Parameter] public EventCallback<T> OnSubmit { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }
    [Parameter] public SelectedDTOParam? SelectedDTO { get; set; }
    [Parameter] public bool IsLoading { get; set; }
    [Parameter] public EventCallback? ComponentIsLoaded { get; set; }
    private UsuarioGetDTO usuario;
    private string token;
    private string basePath = AppDomain.CurrentDomain.BaseDirectory;

    private ElementReference InputFocus;
    private bool firstCall { get; set; } = false;
    private string Title => "Baixar QR Code";
    private string QrCodeUrl = "";

    private int selectedOption = 1;
    private int selectedModel;
    private List<QrCodeLayoutGetDTO> modelList = new();

    private Dictionary<string, string> validationErrors = new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JSRuntime.InvokeVoidAsync("handleEscKey", DotNetObjectReference.Create(this));
            await JSRuntime.InvokeVoidAsync("handleModalEnterKey", DotNetObjectReference.Create(this));
            token = await Provider.GetTokenAsync();
            //await GetUser();
            usuario = Provider.UsuarioOwner;

            if (ComponentIsLoaded is EventCallback isLoaded)
            {
                await isLoaded.InvokeAsync();
            }
        }
    }

    async Task GetUser()
    {
        HttpClient.DefaultRequestHeaders.Authorization =
            new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);

        var result = await HttpClient.GetFromJsonAsync<UsuarioGetDTO>("/api/authentication/getCompanyID");
        usuario = result;
    }

    protected override void OnParametersSet()
    {
        if (!firstCall && SelectedDTO is MesaGetDTO mesa)
        {
            QrCodeUrl = mesa.QrCode;
            LoadModelsFromApi();
            firstCall = true;
        }
    }

    private async Task LoadModelsFromApi()
    {
        try
        {
            modelList = await QrCodeLayoutService.GetData(ValidateSelectedCompanyID());
            StateHasChanged();
        } catch (Exception err)
        {
            throw err;
        }
    }

    string downloadUrl;

    private async Task SubmitAsync()
    {
        if (IsLoading)
        {
            return;
        }

        if (selectedOption != 1 && (selectedModel == null || selectedModel == 0))
        {
            validationErrors["Modelo"] = "Selecione um modelo";
            StateHasChanged();
            return;
        } else
        {
            validationErrors["Modelo"] = "";
        }

        var mesa = SelectedDTO as MesaGetDTO;

        var response = await HttpClient.GetAsync("/api/imagem/download/" + mesa.QrCode);

        var fileName = "QRCode.png";
        var imageBytes = await response.Content.ReadAsByteArrayAsync();

        var base64Image = Convert.ToBase64String(imageBytes);
        downloadUrl = $"data:image/png;base64,{base64Image}";

        string content = string.Empty;

        if (selectedOption == 1)
        {
            content = $@"<div class='frame qr-only' style='max-width: 250px !important; max-height: 250px !important; padding: 0; box-shadow: none; border: none; border-radius: 0;'>
                    <img class='qrCode' src='{downloadUrl}' />
                </div>";
        }
        else
        {
            @foreach (var model in modelList)
            {
                if (model.ID == selectedModel)
                {
                    content = $@"
                            <div class='frame' style='background-color: {model.BackgroundColor}; border: 1px solid {model.BorderColor}; border-radius: {model.BorderRadius}px;'>
                                <div class='header-qrcode'>
                                    <h2 class='title' style='color: {model.TextColor};'>{model.TitleText}</h2>
                                    <p class='description' style='color: {model.TextColor};'>{model.DescriptionText}</p>
                                </div>
                                <img class='qrCode' src='{downloadUrl}' />
                                <h3 style='color: {model.TextColor};'>{mesa.NomeMesa}</h3>
                                <p style='color: {model.TextColor};'>www.escolha.ai</p>
                            </div>";
                }
            }
        }

        await JSRuntime.InvokeVoidAsync("downloadDivAsImage", content, mesa.NomeMesa.Replace(" ", "-"));
    }

    private async Task CancelAsync()
    {
        await Task.Yield();
        await OnCancel.InvokeAsync();
    }

    private void SetSelectedOption(int value)
    {
        selectedOption = value;
    }

    private void OpenCreateFrameModal()
    {
        ModalService.OpenModal(
            "CreatingFrame",
            onConfirmWithParameter: async (frame) => await CreateNewLayoutConfirm((QrCodeLayoutAddDTO)frame),
            onCancel: async () => await CreateNewLayoutCancel()
        );

        StateHasChanged();
    }

    private async Task CreateNewLayoutConfirm(QrCodeLayoutAddDTO qrCodeLayout)
    {
        try
        {
            await QrCodeLayoutService.OnCreateQrCodeLayoutConfirm(ValidateSelectedCompanyID(), qrCodeLayout);
            await LoadModelsFromApi();

            ModalService.CloseModal("CreatingFrame");
        } catch (Exception err)
        {
            throw err;
        }
    }

    private Task CreateNewLayoutCancel()
    {
        ModalService.CloseModal("CreatingFrame");
        return Task.CompletedTask;
    }

    private int ValidateSelectedCompanyID()
    {
        if (usuario != null && EmpresaService.EmpresaSelecionada == 0)
        {
            return usuario.EmpresaID ?? 0;
        }

        return EmpresaService.EmpresaSelecionada;
    }
}

<div>
    <div class="form-header">
        <div class="header">
            <div class="content-header">
                <div class="icon"><i class="fa-solid fa-qrcode"></i></div>
                <div class="title-container">
                    <h4 class="title">@Title</h4>
                </div>
            </div>
            <div class="close" @onclick="CancelAsync"><i class="fa-solid fa-x"></i></div>
        </div>
    </div>
    <form class="form-body">
        <div class="content-inputs">
            <div class="inputs">
                <input class="radio-group" type="radio" id="modeloPadrao1" name="modelo" @onchange="() => SetSelectedOption(1)" checked="@(selectedOption == 1)" />

                <label class="radio-label" for="modeloPadrao1">
                    Modelo Padrão
                </label>
            </div>
            <div class="inputs">
                <input class="radio-group" type="radio" id="modeloPadrao2" name="modelo" @onchange="() => SetSelectedOption(2)" checked="@(selectedOption == 2)" />

                <label class="radio-label" for="modeloPadrao2">
                    Modelo Personalizado
                </label>
            </div>
        </div>
        <div class="custom-model-option @(selectedOption != 2 ? "disabled-group" : "")">
            <div class="inputs-drop">
                <label>
                    Selecione o modelo
                </label>
                <div class="container-model">
                    <RadzenDropDown AllowClear="true" @bind-Value="selectedModel" AllowVirtualization="true" Name="DropDownModels"
                                AllowFiltering="true" Data="@modelList" TextProperty="Nome" ValueProperty="ID" class="models-dropdown" />
                    <button @onclick="OpenCreateFrameModal" class="button-green new" type="button">Criar modelo</button>
                </div>
                <span class="error">@validationErrors.GetValueOrDefault("Modelo")</span>
            </div>
        </div>
    </form>
    <div class="form-footer">
        <button type="button" @onclick="CancelAsync" class="cancel rz-ripple" disabled="@IsLoading"><span>Cancelar</span></button>
        <button type="button" @onclick="SubmitAsync" class="confirm rz-ripple button-green">
            @if (IsLoading)
            {
                <SpinnerLoader PrimaryColor="#FFFFFF" SecondaryColor="#118AB2" Size="20" />
            }
            else
            {
                <span>Baixar</span>
            }
        </button>
    </div>
</div>

<style>
    .rz-colorpicker-popup {
        user-select: none !important;
    }

    .create-model-button {
        margin-left: 10px;
        background-color: #118AB2;
        color: white;
        border: none;
        padding: 5px 10px;
        cursor: pointer;
    }

    body .models-dropdown:hover {
        border: 1px solid #D0D5DD !important;
    }

    .rz-dropdown-panel {
        z-index: 100001 !important;
    }

    body .models-dropdown {
        font-size: 0.875rem;
        line-height: 1.25rem;
        color: #073B4C;
        font-weight: 500;
        border: 1px solid #D0D5DD;
        border-radius: 0.375rem;
        letter-spacing: normal;
        transition: border 0.2s ease;
        outline: none;
        box-shadow: 4px 4px 3px rgba(0, 0, 0, 0.02);
        padding: 9px 12px;
        width: 100%;
        min-width: initial !important;
        max-width: initial !important;
        font-size: 14px !important;
    }
</style>

<script type="text/javascript">
    document.querySelector('form').addEventListener('submit', function(event) {
        event.preventDefault();
    });

    window.downloadDivAsImage = function (htmlContent, mesa) {
        const style = document.createElement('style');
        style.innerHTML = `
            .qrCode {
                width: 250px;
                height: 250px;
                background-size: cover;
                background-position: center;
                margin: 0 auto;
            }
            .qr-only .qrCode, .qr-only.qrCode {
                border: none !important;
                border-radius: 0 !important;
                box-shadow: none !important;
                background: none !important;
            }
            .qr-only {
                width: 250px !important;
                height: 250px !important;
                min-width: 250px !important;
                min-height: 250px !important;
                display: flex;
                justify-content: center;
                align-items: center;
                background-color: transparent;
                box-shadow: none;
                padding: 0;
                border: none;
            }
            .qr-only {
                background: none !important;
            }
            .frame {
                min-width: 350px;
                max-width: 350px;
                width: 100%;
                min-height: 500px;
                height: 100%;
                display: flex;
                flex-direction: column;
                justify-content: space-between;
                text-align: center;
                align-items: center;
                padding: 0.8rem;
                box-shadow: 4px 4px 3px rgba(0, 0, 0, 0.04);
            }
            .header-qrcode {
                display: flex;
                flex-direction: column;
                padding-top: 1rem;
                max-width: 322px;
                word-wrap: break-word;
                overflow-wrap: break-word;
            }
            .header-qrcode .title {
                font-size: 1.5rem;
                line-height: 1.25rem;
                font-weight: 500;
            }
            .header-qrcode .description {
                margin-top: 0.5rem;
                font-size: 0.875rem;
                line-height: 1.25rem;
                font-weight: 500;
            }
        `;
        document.head.appendChild(style);

        const temporaryDiv = document.createElement('div');

        if (htmlContent.includes("qr-only")) {
            temporaryDiv.style.maxWidth = "250px";
            temporaryDiv.style.maxHeight = "250px";
        } else {
            temporaryDiv.style.maxWidth = "350px";
            temporaryDiv.style.minHeight = "500px";
        }

        temporaryDiv.innerHTML = htmlContent;
        document.body.appendChild(temporaryDiv);

        html2canvas(temporaryDiv, {
            useCORS: true,
            allowTaint: true,
            backgroundColor: null
        }).then((canvas) => {
            const link = document.createElement("a");
            link.download = `QrCode-${mesa}.jpg`;
            link.href = canvas.toDataURL("image/jpg");
            link.click();

            document.body.removeChild(temporaryDiv);
            document.head.removeChild(style);
        });
    };
</script>