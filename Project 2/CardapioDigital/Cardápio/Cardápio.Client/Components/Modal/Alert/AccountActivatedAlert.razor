@typeparam T

@code {
    [Parameter] public EventCallback OnCancel { get; set; }
    [Parameter] public bool IsLoading { get; set; }

    private async Task CancelAsync()
    {
        await OnCancel.InvokeAsync();
    }
}

<div class="header">
    <div class="close"><a href="/login"><i class="fa-solid fa-x"></i></a></div>
</div>
<div class="success-message">
    <div class="icon">
        <i class="fa-solid fa-check"></i>
    </div>
    <h4 class="title">Conta ativada <br /> com sucesso</h4>
    <p class="message">Entre na sua conta utilizando seu E-mail e Senha na página de login.</p>
    <span class="redirect" @onclick="CancelAsync">Para voltar à página de login, <a href="/login" class="link">clique aqui</a></span>
</div>