    private ProductModal<T, SelectedDTO> requestedUserAlertRef;

    private string modalId = "modal-" + Guid.NewGuid().ToString();
    public bool IsLoading = false;


    private bool isReadyToRender = false;
    private bool isLoaded = false;
    private bool hasSynced = false;
	

    protected async override Task OnParametersSetAsync()
    {
        if (IsOpen)
        {
            if (!isReadyToRender)
            {
                isReadyToRender = true;
                await SyncComponent(); // <-- troque _ = por await
            }
        }
        else
        {
            isReadyToRender = false;
            StateHasChanged();
        }

        if (IsOpen && isReadyToRender && !hasSynced)
        {
            await SyncComponent();
            hasSynced = true;
        }

        if (IsOpen && isReadyToRender && (!ActionType.Contains("create") && !ActionType.Contains("editing")) && !hasSynced)
        {
            await SyncComponent();
            hasSynced = true;
        }

        if (!IsOpen)
        {
            hasSynced = false;
        }
    }

    private async Task ConfirmAsync(T value)
    {
        try
        {
            if (IsOpen)
            {
                IsLoading = true;
                await OnConfirm.InvokeAsync(value);
                await JSRuntime.InvokeVoidAsync("resetModalState", modalId);

                IsOpen = false;
                isReadyToRender = false;
                await JSRuntime.InvokeVoidAsync("removeEnterKeyListener");
                await JSRuntime.InvokeVoidAsync("removeEscKeyListener");
                await JSRuntime.InvokeVoidAsync("removeOverflow");

                CloseSecondaryModal();
                StateHasChanged();
            }
        }
        catch (Exception err)
        {
            throw err;
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task CancelAsync()
    {
        if (IsOpen)
        {
            CloseSecondaryModal();

            IsOpen = false;
            await OnCancel.InvokeAsync();
            isReadyToRender = false;
            await JSRuntime.InvokeVoidAsync("removeEnterKeyListener");
            await JSRuntime.InvokeVoidAsync("removeEscKeyListener");
            await JSRuntime.InvokeVoidAsync("resetModalState", modalId);
            await JSRuntime.InvokeVoidAsync("removeOverflow");

            await Task.Yield();

            StateHasChanged();
        }
    }

    private async Task SyncComponent()
    {
        try
        {
            await Task.Yield();
            await JSRuntime.InvokeVoidAsync("makeModalDraggable", modalId);

            if (IsOpen) {
                await JSRuntime.InvokeVoidAsync("addOverflow");
            } else {
                await JSRuntime.InvokeVoidAsync("removeOverflow");
            }
        }
        catch (Microsoft.JSInterop.JSDisconnectedException)
        {
            // Ignorar erros de JavaScript quando o circuito está desconectado
            Console.WriteLine("[Modal] JavaScript desconectado durante SyncComponent");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[Modal] Erro no SyncComponent: {ex.Message}");
        }
    }

    private async Task HandleSecondaryModalOpen()
    {
        StateContainer.SecondaryModalIsOpen = true;

        await OnSecondaryModalOpen.InvokeAsync();
    }

    private void CloseSecondaryModal()
    {
        if (ActionType.Contains("editing/categoria") || ActionType.Contains("creating/categoria"))
        {
            StateContainer.SecondaryModalIsOpen = false;
        }
    }

