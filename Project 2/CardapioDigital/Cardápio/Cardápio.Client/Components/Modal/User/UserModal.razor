@typeparam T;
@typeparam SelectedDTOParam
@inject IJSRuntime JSRuntime;
@inject HttpClient HttpClient;
@inject Cardápio.Client.Infra.Provider.CustomAuthenticationStateProvider Provider;
@inject Cardápio.Client.Pages.Empresas.EmpresaService EmpresaService;

@using Radzen;
@using System.Collections.ObjectModel;
@using Cardápio.Client.Dto;

<style>
    .rz-dropdown-panel {
        z-index: 100001 !important;
    }

    .radio-group {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .radio-group label {
        margin-right: 5px;
    }

    .rz-dropdown {
        font-size: 0.875rem;
        line-height: 1.25rem;
        color: #073B4C;
        font-weight: 500;
        border: 1px solid #D0D5DD;
        border-radius: 0.375rem;
        letter-spacing: normal;
        transition: border 0.2s ease;
        outline: none;
        box-shadow: 4px 4px 3px rgba(0, 0, 0, 0.02);
        padding: 9px 12px;
        width: 100%;
    }
</style>

@code {
    [Parameter] public string ActionType { get; set; }
    [Parameter] public EventCallback<T> OnSubmit { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }
    [Parameter] public SelectedDTOParam? SelectedDTO { get; set; }
    [Parameter] public bool IsLoading { get; set; }
    [Parameter] public EventCallback? ComponentIsLoaded { get; set; }
    [Parameter] public int? EmpresaID { get; set; }


    private ElementReference InputFocus;
    private Dictionary<string, string> validationErrors = new();

    private ObservableCollection<EmpresaGetDTO> empresas = new ObservableCollection<EmpresaGetDTO>();
    private List<TipoDTO> tipos = new List<TipoDTO>
    {
        new TipoDTO { ID = 2, Nome = "Comum" },
        new TipoDTO { ID = 1, Nome = "Administrador" }
    };
    private UsuarioGetDTO usuario = new UsuarioGetDTO();
    private bool firstCall { get; set; } = false;
    private string token;
    private string Title => ActionType == "creating/usuario" ? "Registrar Usuário" : "Editar Usuário";

    private string nome { get; set; } = string.Empty;
    private string email { get; set; } = string.Empty;
    private string password { get; set; } = string.Empty;
    private int? empresaSelecionada = null;
    private int? tipoSelecionado = null;
    private bool? isAtivo { get; set; }


    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JSRuntime.InvokeVoidAsync("handleEscKey", DotNetObjectReference.Create(this));
            await JSRuntime.InvokeVoidAsync("handleModalEnterKey", DotNetObjectReference.Create(this));

            token = await Provider.GetTokenAsync();
            //await GetUser();
            usuario = Provider.UsuarioOwner;
            await GetData();

            await FocusInputRecursively();
        }
    }

    private async Task FocusInputRecursively()
    {
        while (true)
        {
            bool isFocused = await JSRuntime.InvokeAsync<bool>("tryFocusElementDirect", InputFocus);

            if (isFocused)
            {
                break;
            }
        }
    }

    async Task GetUser()
    {
        HttpClient.DefaultRequestHeaders.Authorization =
            new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);

        var result = await HttpClient.GetFromJsonAsync<UsuarioGetDTO>("/api/authentication/getCompanyID");
        usuario = result;
    }

    async Task GetData()
    {
        try
        {
            // não precisa mais buscar empresas — EmpresaID vem direto como parâmetro
            if (ComponentIsLoaded is EventCallback isLoaded)
                await isLoaded.InvokeAsync();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[GetData] erro: {ex.Message}");
        } 
        {
            if (ComponentIsLoaded is EventCallback isLoaded)
                await isLoaded.InvokeAsync();
            StateHasChanged();
        }
    }

    protected async override Task OnParametersSetAsync()
    {
        if (!firstCall && ActionType.Contains("editing") && SelectedDTO is UsuarioGetDTO usuarioSelected)
        {
            firstCall = true; // <-- mova para ANTES do GetData

            if (usuarioSelected != null)
            {
                nome = usuarioSelected.Nome;
                email = usuarioSelected.Email;
                password = usuarioSelected.Password;
                empresaSelecionada = usuarioSelected.EmpresaID;
                tipoSelecionado = usuarioSelected.UsuarioTipoID;
                isAtivo = usuarioSelected.Ativo;
            }

            await GetData();
        }
    }
    private void OnEmpresaChanged(ChangeEventArgs e)
    {
        var value = e.Value?.ToString();
        Console.WriteLine($"[OnEmpresaChanged] empresaSelecionada: {value}");

        empresaSelecionada = !string.IsNullOrEmpty(value) && int.TryParse(value, out var id)
            ? id
            : (int?)null;
    }

    private void OnTipoChanged(ChangeEventArgs e)
    {
        var val = e.Value?.ToString();
        tipoSelecionado = !string.IsNullOrEmpty(val) ? int.Parse(val) : (int?)null;
        Console.WriteLine($"[OnTipoChanged] tipoSelecionado: {tipoSelecionado}");
    }

    private async Task SubmitAsync()
    {
        try
        {
            if (ActionType == "creating/usuario" && !IsLoading)
            {
                await SendCreate();
            }
            if (ActionType == "editing/usuario" && !IsLoading)
            {
                await SendEdit();
            }
        }
        catch (Exception err)
        {
            Console.WriteLine($"[UsuarioModal] Erro: {err.Message}"); // <-- adicione
            await ValidateApiResponseError(err);
        }
        finally
        {
            if (ComponentIsLoaded is EventCallback isLoaded)
            {
                await isLoaded.InvokeAsync();
            }
        }
    }

    [JSInvokable("HandleModalEnterKey")]
    public async Task HandleModalEnterKey()
    {
        if (IsLoading)
        {
            return;
        }

        StateHasChanged();
        await SubmitAsync();
    }

    [JSInvokable("HandleEscapeKey")]
    public async Task HandleEscapeKey()
    {
        await CancelAsync();
    }

    private async Task CancelAsync()
    {
        ResetFields();
        await OnCancel.InvokeAsync();
    }
    private async Task SendCreate()
    {
        Console.WriteLine($"[SendCreate] empresaSelecionada: {empresaSelecionada}, tipoSelecionado: {tipoSelecionado}");

        UsuarioAddDTO data = new UsuarioAddDTO
        {
            Nome = nome,
            Email = email,
            Password = password,
            EmpresaID = EmpresaID,
            UsuarioTipoID = tipoSelecionado.Value,
        };

        if (tipoSelecionado == null || tipoSelecionado == 0)
        {
            validationErrors["UsuarioTipoID"] = "Tipo é obrigatório.";
            StateHasChanged();
            return;
        }

        // Remove o segundo if string.IsNullOrEmpty — era inválido para int?

        Console.WriteLine($"[SendCreate] EmpresaID param: {EmpresaID}");

        if (!await ValidateEntityAsync(data, nameof(data.Nome), nameof(data.Email), nameof(data.Password)))
            return;

        await OnSubmit.InvokeAsync((T)(object)data);
        ResetFields();
    }

    private async Task SendEdit()
    {
        UsuarioUpdateDTO data = new UsuarioUpdateDTO
            {
                Nome = nome,
                Email = email,
                Password = password,
                EmpresaID = int.TryParse(empresaSelecionada.Value.ToString(), out var empresaID) ? empresaID : 0,
                UsuarioTipoID = int.TryParse(tipoSelecionado.Value.ToString(), out var tipoID) ? tipoID : 0,
                Ativo = isAtivo.Value
            };

        if (!await ValidateEntityAsync(data, nameof(data.Nome), nameof(data.Email), nameof(data.Password),
            nameof(data.EmpresaID), nameof(data.UsuarioTipoID)))
        {
            return;
        }

        await OnSubmit.InvokeAsync((T)(object)data);
        ResetFields();
    }

    private void ResetFields()
    {
        nome = string.Empty;
        email = string.Empty;
        password = string.Empty;
        empresaSelecionada = null;
        tipoSelecionado = null;
        isAtivo = true;

        firstCall = false;
    }

    private async Task<bool> ValidateEntityAsync<GenericValidate>(GenericValidate entity, params string[] requiredFields)
    {
        var validator = new ValidationService<GenericValidate>();
        var validationResult = validator.Validate(entity, requiredFields);

        if (!validationResult.IsValid)
        {
            validationErrors = validationResult.Errors;
            StateHasChanged();
            return false;
        }

        validationErrors.Clear();
        return true;
    }

    private async Task ValidateApiResponseError(Exception err)
    {
        ValidationErrorResponseApi errorResponse = ValidationErrorResponseApi.ConvertJsonToData(err.Message);
        if (errorResponse.Errors != null)
        {
            foreach (var apiError in errorResponse.Errors)
            {
                foreach (var message in apiError.Value)
                {
                    validationErrors[apiError.Key] = message;
                }
            }
        }

        validationErrors["API"] = "Erro ao processar a solicitação.";
    }

    public class TipoDTO
    {
        public int ID { get; set; }
        public string Nome { get; set; }
    }

    private void OnRadioChanged(bool value)
    {
        isAtivo = value;
    }
}

<div class="form">
    <div class="form-header">
        <div class="header">
            <div class="content-header">
                <div class="icon"><i class="fa-solid fa-box-open"></i></div>
                <div class="title-container">
                    <h4 class="title">@Title</h4>
                </div>
            </div>
            <div class="close" @onclick="CancelAsync"><i class="fa-solid fa-x"></i></div>
        </div>
    </div>
    <form class="form-body">
        <div class="content-inputs">
            <div class="inputs">
                <label>Nome</label>
                <input @ref="InputFocus" @bind="nome" @bind:event="oninput" />
                <span class="error">@validationErrors.GetValueOrDefault("Nome")</span>
            </div>
            <div class="inputs">
                <label>E-mail</label>
                <input @bind="email" @bind:event="oninput" />
                <span class="error">@validationErrors.GetValueOrDefault("Email")?.Replace("Email", "E-mail")</span>
            </div>
            <div class="inputs">
                <label>Senha</label>
                <input @bind="password" @bind:event="oninput" type="password" />
                <span class="error">@validationErrors.GetValueOrDefault("Password")?.Replace("O Password", "A Senha")</span>
            </div>

            @if (usuario != null && (usuario.UsuarioTipoID == 4 || usuario.UsuarioTipoID == 1 || usuario.UsuarioTipoID == 3))
            {
                <div class="wrap-inputs" style="align-items: start;">
                    <div class="inputs select">
                        <label>Tipo</label>
                      

                        <select @onchange="OnTipoChanged">
                            <option value="">Selecione o tipo</option>
                            @foreach (var tipo in tipos)
                            {
                                <option value="@tipo.ID" selected="@(tipoSelecionado == tipo.ID)">@tipo.Nome</option>
                            }
                        </select>
                        <span class="error">@validationErrors.GetValueOrDefault("UsuarioTipoID")?.Replace("A UsuarioTipoID", "O Tipo")</span>
                    </div>
                </div>
            }

            @if (ActionType.Contains("editing") && usuario.UsuarioTipoID == 4 ||
                        (SelectedDTO is UsuarioGetDTO usuarioDTOStatus &&
                        usuario != null &&
                        usuario.ID != usuarioDTOStatus.ID && usuarioDTOStatus.UsuarioTipoID != 1))
            {
                <div class="inputs">
                    <label>Status</label>
                    <div class="radios">
                        <div class="input-radio">
                            <input type="radio" id="ativo" name="status" value="true" checked="@isAtivo" @onchange="() => OnRadioChanged(true)" />
                            <label class="active" for="ativo">Ativo</label>
                        </div>
                        <div class="input-radio">
                            <input type="radio" id="desativado" name="status" value="false" checked="@(isAtivo == false)" @onchange="() => OnRadioChanged(false)" />
                            <label class="disabled" for="desativado">Desativado</label>
                        </div>
                    </div>
                </div>
            }
        </div>
    </form>
    <div class="form-footer">
        <button type="button" @onclick="CancelAsync" class="cancel rz-ripple" disabled="@IsLoading"><span>Cancelar</span></button>
        <button type="button" @onclick="SubmitAsync" class="confirm rz-ripple button-green" disabled="@IsLoading">
            @if (IsLoading)
            {
                <SpinnerLoader PrimaryColor="#FFFFFF" SecondaryColor="#118AB2" Size="20" />
            }
            else
            {
                <span>Salvar</span>
            }
        </button>
    </div>
</div>

<script type="text/javascript">
    document.querySelector('form').addEventListener('submit', function(event) {
        event.preventDefault();
    });

    window.tryFocusElementDirect = async function (element) {
        if (element && document.activeElement !== element) {
            element.focus();
            return document.activeElement === element;
        }

        return document.activeElement === element;
    };
</script>