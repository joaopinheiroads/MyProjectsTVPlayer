                                else
                                {
                                    <h5 class="price number">R$ <span class="number value">@(product?.Preco ?? 0)</span></h5>
                                }
                            }
                            else
                            {
                                <h5 class="price number">R$ 0</h5>
                            }
                        </div>
                    </div>
                    @if (product != null && product?.ColGrupoAdicional != null && product.ColGrupoAdicional.Any())
                    {
                        <div class="additional-group-container">
                            @foreach (var groupAdditional in product.ColGrupoAdicional.OrderBy(pg => pg.Posicao))
                            {
                                <div class="additional-group">
                                    <div class="title-group">
                                        <div class="info-title">
                                            <h4>@groupAdditional.Nome</h4>
                                            @if (groupAdditional.Minimo > 0)
                                            {
                                                if (groupAdditional.Maximo > 1)
                                                {
                                                    <span>Escolha @groupAdditional.Maximo opções</span>
                                                }
                                                else
                                                {
                                                    <span>Escolha @groupAdditional.Maximo opção</span>
                                                }
                                            }
                                            else
                                            {
                                                if (groupAdditional.Maximo > 1)
                                                {
                                                    <span>Escolha até @groupAdditional.Maximo opções</span>
                                                }
                                                else
                                                {
                                                    <span>Escolha até @groupAdditional.Maximo opção</span>
                                                }
                                            }
                                        </div>
                                        @if (groupAdditional.Minimo > 0)
                                        {
                                            <div class="badge-required">
                                                Obrigatório
