                                                    <div class="info-additional">
                                                        <p>@additional.Nome</p>
                                                        <span>R$ <span class="number">@additional.Preco</span></span>
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}

