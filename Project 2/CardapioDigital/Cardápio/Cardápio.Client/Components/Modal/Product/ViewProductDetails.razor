@code {
    // Renderização dos itens do carrinho com opção de remover
    private RenderFragment RenderCarrinhoItens() => builder =>
    {
        var seq = 0;
        CartService.GetCartItemsAsync().ContinueWith(task =>
        {
            var itens = task.Result;
            foreach (var item in itens)
            {
                builder.OpenElement(seq++, "div");
                builder.AddAttribute(seq++, "class", "cart-item");
                builder.AddContent(seq++, $"{item.Name} - Qtd: {item.Quantity}");
                builder.OpenElement(seq++, "button");
                builder.AddAttribute(seq++, "class", "rz-ripple button-red");
                builder.AddAttribute(seq++, "onclick", EventCallback.Factory.Create(this, () => RemoverItemDoCarrinho(item.ItemCartId)));
                builder.AddContent(seq++, "Remover");
                builder.CloseElement();
                builder.CloseElement();
            }
        });
    };
    private async Task RemoverItemDoCarrinho(string itemCartId)
    {
        await CartService.RemoveFromCartAsync(itemCartId);
        StateHasChanged();
    }
    private Dictionary<int, int> quantities = new();
    private Dictionary<int, int> selectedRadioValues = new();
    private int quantity = 1;
    private decimal totalPriceView = 0;

    private decimal totalPrice => productClient?.Preco.HasValue == true ? productClient.Preco.Value * quantity : 0;
    private ProdutoGetDTO productClient = new();
    private bool wasValid = true;

    private async void OnRadioClicked(GrupoAdicionalGetDTO group, GrupoAdicionalItemGetDTO additional)
    {
        if (selectedRadioValues.TryGetValue(group.ID, out int currentId) && currentId == additional.ID)
        {
            selectedRadioValues.Remove(group.ID);
        }
        else
        {
            selectedRadioValues[group.ID] = additional.ID;
        }

        await RecalculateTotalPrice();
    }

    private async Task RecalculateTotalPrice()
    {
        // Calcular preço base do produto (com possível promoção)
        var precoBase = Math.Round(CalcularPrecoAtual(productClient), 2);
        
        // Calcular preço dos adicionais (independente da quantidade do produto)
        decimal precoAdicionais = 0;

        foreach (var groupAdditional in productClient.ColGrupoAdicional)
        {
            if (groupAdditional.TipoNome is not null)
            {
                decimal groupValue = groupAdditional.TipoNome switch
                {
                    "Média de valor" => Math.Round(CalculateAverageValue(groupAdditional), 2),
                    "Maior valor" => Math.Round(CalculateMaxSelectedValue(groupAdditional), 2),
                    "Somatório" => Math.Round(CalculateSumValue(groupAdditional), 2),
                    _ => 0
                };

                if (selectedRadioValues.ContainsKey(groupAdditional.ID))
                {
                    var selectedItem = groupAdditional.ColGrupoAdicionalItem
                        .FirstOrDefault(item => item.ID == selectedRadioValues[groupAdditional.ID]);

                    if (selectedItem != null)
                    {
                        precoAdicionais += Math.Round(selectedItem.Preco ?? 0, 2);
                    }
                }

                precoAdicionais += groupValue;
            }
        }

        // Fórmula correta: (preço base * quantidade) + preço adicionais
        totalPriceView = (precoBase * quantity) + precoAdicionais;

        StateHasChanged();
        await Task.Yield();
    }

    private decimal CalculateAverageValue(GrupoAdicionalGetDTO groupAdditional)
    {
        var selectedItems = groupAdditional.ColGrupoAdicionalItem
            .Where(item => quantities.GetValueOrDefault(item.ID, 0) > 0)
            .ToList();

        if (!selectedItems.Any()) return 0;

        decimal totalValue = 0;
        int totalQuantity = 0;

        foreach (var item in selectedItems)
        {
            int itemQuantity = quantities.GetValueOrDefault(item.ID, 0);
            decimal itemTotalValue = (item.Preco ?? 0) * itemQuantity;

            totalValue += itemTotalValue;
            totalQuantity += itemQuantity;
        }

        decimal averageValue = totalQuantity > 0 ? totalValue / totalQuantity : 0;

        return averageValue;
    }

    private decimal CalculateMaxSelectedValue(GrupoAdicionalGetDTO groupAdditional)
    {
        var selectedItems = groupAdditional.ColGrupoAdicionalItem
            .Where(item => quantities.GetValueOrDefault(item.ID, 0) > 0)
            .ToList();

        if (!selectedItems.Any()) return 0;

        decimal maxValue = 0;

        foreach (var item in selectedItems)
        {
            var itemQuantity = quantities.GetValueOrDefault(item.ID, 0);

            decimal itemValue = (item.Preco ?? 0) * (itemQuantity > 1 ? 1 : itemQuantity);

            maxValue = Math.Max(maxValue, itemValue);
        }

        return maxValue;
    }

    private decimal CalculateSumValue(GrupoAdicionalGetDTO groupAdditional)
    {
        return groupAdditional.ColGrupoAdicionalItem
            .Sum(item => (item.Preco ?? 0) * quantities.GetValueOrDefault(item.ID, 0));
    }

    private bool IsSelectionValid()
    {
        if (productClient?.ColGrupoAdicional == null) return true;

        bool isValid = productClient.ColGrupoAdicional.All(group =>
        {
            int totalSelected = group.ColGrupoAdicionalItem.Sum(item =>
                quantities.GetValueOrDefault(item.ID, 0) +
                (selectedRadioValues.TryGetValue(group.ID, out int radioId) && radioId == item.ID ? 1 : 0));

            return totalSelected >= group.Minimo && totalSelected <= group.Maximo;
        });

        if (isValid != wasValid)
        {
            wasValid = isValid;
            StateHasChanged();
        }

        return isValid;
    }

    private async void IncreaseQuantityGroup(GrupoAdicionalGetDTO groupAdditional, GrupoAdicionalItemGetDTO additional)
    {
        int totalGroupQuantity = groupAdditional.ColGrupoAdicionalItem
            .Sum(item => quantities.GetValueOrDefault(item.ID, 0));

        if (totalGroupQuantity < groupAdditional.Maximo)
        {
            quantities[additional.ID] = quantities.GetValueOrDefault(additional.ID, 0) + 1;
            await RecalculateTotalPrice();
        }
    }

    private async void DecreaseQuantityGroup(GrupoAdicionalGetDTO groupAdditional, GrupoAdicionalItemGetDTO additional)
    {
        if (quantities.GetValueOrDefault(additional.ID, 0) > 0)
        {
            quantities[additional.ID]--;
            if (quantities[additional.ID] == 0)
            {
                quantities.Remove(additional.ID);
            }

            await RecalculateTotalPrice();
        }
    }

    private async void IncreaseQuantity()
    {
        quantity++;
        await RecalculateTotalPrice();
    }

    private async void DecreaseQuantity()
    {
        if (quantity > 1)
        {
            quantity--;
            await RecalculateTotalPrice();
        }
    }

    /// <summary>
    /// Calcula o preço atual do produto considerando promoções ativas por horário
    /// </summary>
    private decimal CalcularPrecoAtual(ProdutoGetDTO produto)
    {
        // Se não há promoções por horário, retorna preço original
        if (produto.PromocoesPorHorario == null || !produto.PromocoesPorHorario.Any())
        {
            return produto.Preco ?? 0;
        }

        var agora = DateTime.Now;
        var diaSemanaAtual = GetDiaSemanaPortugues(agora.DayOfWeek);
        var horaAtual = agora.TimeOfDay;


        // Buscar promoção ativa no momento atual
        var promocaoAtiva = produto.PromocoesPorHorario
            .Where(p => p.DiaSemana == diaSemanaAtual)
            .Where(p => 
            {
                if (TimeSpan.TryParse(p.HoraInicio, out var horaInicio) && 
                    TimeSpan.TryParse(p.HoraFim, out var horaFim))
                {
                    return horaAtual >= horaInicio && horaAtual <= horaFim;
                }
                return false;
            })
            .OrderBy(p => p.PrecoPromocional)
            .FirstOrDefault();

        if (promocaoAtiva != null)
        {
            return promocaoAtiva.PrecoPromocional;
        }

        return produto.Preco ?? 0;
    }

    /// <summary>
    /// Converte DayOfWeek para string em português
    /// </summary>
    private static string GetDiaSemanaPortugues(DayOfWeek dayOfWeek)
    {
        return dayOfWeek switch
        {
            DayOfWeek.Sunday => "Domingo",
            DayOfWeek.Monday => "Segunda",
            DayOfWeek.Tuesday => "Terça",
            DayOfWeek.Wednesday => "Quarta",
            DayOfWeek.Thursday => "Quinta",
            DayOfWeek.Friday => "Sexta",
            DayOfWeek.Saturday => "Sábado",
            _ => "Segunda"
        };
    }
}