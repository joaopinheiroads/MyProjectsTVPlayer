@typeparam T;
@typeparam SelectedDTO;

@inject IJSRuntime JSRuntime;
@inject NavigationManager NavigationManager;
@inject Cardápio.Client.Pages.ConfirmarPedido.PedidoStorage PedidoStorage;
@inject Cardápio.Client.Pages.Cardapio.ShoppingCartContext.ShoppingCartContextService CartService;

@using Cardápio.Client.Pages.Cardapio.ShoppingCartContext;

@code {
    [Parameter] public string ActionType { get; set; } = string.Empty;
    [Parameter] public EventCallback<T?> OnSubmit { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }
    [Parameter] public SelectedDTO? ProductSelected { get; set; }
    [Parameter] public EventCallback? ComponentIsLoaded { get; set; }

    private Dictionary<string, string> validationErrors = new();

    private string description { get; set; } = string.Empty;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JSRuntime.InvokeVoidAsync("handleEscKey", DotNetObjectReference.Create(this));

            if (ComponentIsLoaded is EventCallback isLoaded)
            {
                await isLoaded.InvokeAsync();
            }

            await Task.Yield();
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (ProductSelected is ProdutoGetDTO produtoSelecionado)
        {
            // Calcular preço promocional atual baseado nos horários
            var precoAtual = CalcularPrecoAtual(produtoSelecionado);
            totalPriceView = precoAtual;

            productClient = produtoSelecionado;

            if (produtoSelecionado.CartItem != null && !string.IsNullOrEmpty(produtoSelecionado.CartItem.Observation))
            {
                description = produtoSelecionado.CartItem.Observation;
            }

            if (produtoSelecionado.CartItem != null)
            {
                quantity = produtoSelecionado.CartItem.Quantity;
            }

            if (produtoSelecionado.CartItem?.AdditionalGroups != null && ActionType.Contains("view-cart"))
            {
                foreach (var cartGroup in produtoSelecionado.CartItem.AdditionalGroups)
                {
                    var productGroup = produtoSelecionado.ColGrupoAdicional
                        .OrderBy(pg => pg.Posicao)
                        .FirstOrDefault(g => g.Nome == cartGroup.GroupName);

                    if (productGroup != null)
                    {
                        foreach (var cartItem in cartGroup.Items)
                        {
                            var additionalItem = productGroup.ColGrupoAdicionalItem
                                .FirstOrDefault(i => i.Nome == cartItem.Name);

                            if (additionalItem != null)
                            {
                                if (productGroup.Maximo == 1)
                                {
                                    selectedRadioValues[productGroup.ID] = additionalItem.ID;
                                }
                                else
                                {
                                    quantities[additionalItem.ID] = cartItem.Quantity;
                                }
                            }
                        }
                    }
                }
            }

            await RecalculateTotalPrice();
        }
    }

    [JSInvokable("HandleEscapeKey")]
    public async Task HandleEscapeKey()
    {
        await CancelAsync();
    }

    [JSInvokable("CloseModal")]
    public async Task CloseModal()
    {
        await CancelAsync();
    }

    public async Task SubmitAsync()
    {
        try
        {
            if (ProductSelected is ProdutoGetDTO productModel)
            {
                var precoAtual = CalcularPrecoAtual(productModel);
                var temPromocao = precoAtual < productModel.Preco;
                
                CartModel data = new CartModel
                    {
                        Id = productModel.ID,
                        ImageUrl = productModel.ImagemThumbnail,
                        Name = productModel.Nome,
                        Price = precoAtual, // Preço atual (promocional se houver promoção)
                        OriginalPrice = temPromocao ? productModel.Preco : null, // Preço original apenas se há promoção
                        HasPromotion = temPromocao,
                        Quantity = quantity,
                        Observation = description,
                        AdditionalGroups = new List<CartAdditionalGroupModel>()
                    };

                foreach (var groupAdditional in productModel.ColGrupoAdicional)
                {
                    var selectedItems = groupAdditional.ColGrupoAdicionalItem
                        .Where(item => quantities.GetValueOrDefault(item.ID, 0) > 0)
                        .ToList();

                    if (selectedRadioValues.TryGetValue(groupAdditional.ID, out int selectedRadioId))
                    {
                        var radioItem = groupAdditional.ColGrupoAdicionalItem
                            .FirstOrDefault(item => item.ID == selectedRadioId);

                        if (radioItem != null && !selectedItems.Contains(radioItem))
                        {
                            selectedItems.Add(radioItem);
                        }
                    }

                    if (selectedItems.Any())
                    {
                        Console.WriteLine($"[DEBUG] Grupo: {groupAdditional.Nome}");
                        
                        var groupModel = new CartAdditionalGroupModel
                            {
                                GroupName = groupAdditional.Nome,
                                Items = selectedItems.Select(item =>
                                {
                                    var isRadioSelected = selectedRadioValues.TryGetValue(groupAdditional.ID, out int radioId) && radioId == item.ID;
                                    var additionalQuantity = isRadioSelected ? 1 : quantities.GetValueOrDefault(item.ID, 0);
                                    

                                    return new CartAdditionalItemModel
                                    {
                                        ID = item.ID,
                                        Name = item.Nome,
                                        UnitPrice = item.Preco ?? 0,
                                        Quantity = additionalQuantity,
                                        TotalPrice = (item.Preco ?? 0) * additionalQuantity
                                    };
                                }).ToList(),
                                GroupTotalPrice = selectedItems.Sum(item =>
                                {
                                    var isRadioSelected = selectedRadioValues.TryGetValue(groupAdditional.ID, out int radioId) && radioId == item.ID;
                                    var additionalQuantity = isRadioSelected ? 1 : quantities.GetValueOrDefault(item.ID, 0);
                                    return (item.Preco ?? 0) * additionalQuantity;
                                })
                            };

                        data.AdditionalGroups.Add(groupModel);
                    }
                }

                if (productModel.CartItem != null)
                {
                    data.ItemCartId = productModel.CartItem.ItemCartId;
                }

                await OnSubmit.InvokeAsync((T)(object)data);
            }

            ResetFields();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erro ao submeter produto: {ex.Message}");
        }
    }

    private async Task CancelAsync()
    {
        await OnCancel.InvokeAsync();
        ResetFields();
    }

    private void ResetFields()
    {
        quantity = 1;
        description = string.Empty;
        productClient = new ProdutoGetDTO();
        selectedRadioValues = new Dictionary<int, int>();
        quantities = new Dictionary<int, int>();

        StateHasChanged();
    }
}

