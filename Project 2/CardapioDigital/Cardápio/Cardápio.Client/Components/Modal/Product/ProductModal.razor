@typeparam T;
@typeparam SelectedDTOParam
@inject IJSRuntime JSRuntime;
@inject HttpClient HttpClient;
@inject SelectCompanyService EmpresaService;
@inject Cardápio.Client.Infra.Provider.CustomAuthenticationStateProvider Provider;
@inject Cardápio.Client.Pages.Categoria.CategoriaService CategoryService;
@inject StateContainer StateContainer

@using Cardápio.Client.Components.StateModal
@using System.Collections.ObjectModel
@using Cardápio.Client.Components.Modal.Product.Forms
@using Cardápio.Client.Components.Modal.Product.Tabs
@using Cardápio.Client.Components.Modal
@using Radzen

@code {
    [Inject] private ModalService ModalService { get; set; }

    [Parameter] public string ActionType { get; set; }
    [Parameter] public EventCallback<T> OnSubmit { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }
    [Parameter] public EventCallback OnOpenCategoryModal { get; set; }
    [Parameter] public SelectedDTOParam? SelectedDTO { get; set; }
    [Parameter] public bool IsLoading { get; set; }
    [Parameter] public EventCallback ComponentIsLoaded { get; set; }
    [Parameter] public List<CategoriaGetDTO> CategoriesDataAPI { get; set; }

    private Cardápio.Client.Components.Modal.Product.Forms.ProductForm ProductFormReference { get; set; }
    private AdditionalForm AdditionalFormReference { get; set; }
    private HorarioForm HorarioFormReference { get; set; }
    private PromocaoTab PromocaoFormReference { get; set; }
    private PromocaoTab PromocaoFormReferenceHidden { get; set; }

    private bool firstCall { get; set; } = false;

    private string Title => ActionType == "creating/produto" ? "Registrar Produto" : "Editar Produto";
    private MemoryStream selectedBanner = new MemoryStream();
    private UsuarioGetDTO usuario = new UsuarioGetDTO();
    private bool isCreateCategoryModalOpen;
    int selectedIndex = 0;

    private string token;
    private int oldValue;

    private bool imageLoading = false;
    private string ImageDataUrl;

    private Dictionary<string, string> validationErrors = new();
    private ProdutoGetDTO productModel;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        int currentValue = ValidateSelectedCompanyID();

        if (firstRender || oldValue != currentValue)
        {
            await JSRuntime.InvokeVoidAsync("handleEscKey", DotNetObjectReference.Create(this));
            await JSRuntime.InvokeVoidAsync("handleModalEnterKey", DotNetObjectReference.Create(this));

            oldValue = currentValue;

            token = await Provider.GetTokenAsync();
            //await GetUser();
            usuario = Provider.UsuarioOwner;
        }
        
        if (firstRender)
        {
            // Garantir que os componentes hidden foram inicializados
            await Task.Delay(100); // Pequeno delay para garantir renderização
            Console.WriteLine($"[ProductModal] OnAfterRender - PromocaoFormReferenceHidden inicializado: {PromocaoFormReferenceHidden != null}");
        }
    }

    protected override void OnParametersSet()
    {
        if (!firstCall && SelectedDTO is ProdutoGetDTO product)
        {
            Console.WriteLine($"[ProductModal] OnParametersSet - Novo produto selecionado: {product.Nome} (ID: {product.ID})");
            
            // Reset do estado das abas de promoção quando um novo produto é selecionado
            if (PromocaoFormReference != null)
            {
                Console.WriteLine($"[ProductModal] Resetando estado do PromocaoFormReference");
                PromocaoFormReference.ResetState();
            }
            if (PromocaoFormReferenceHidden != null)
            {
                Console.WriteLine($"[ProductModal] Resetando estado do PromocaoFormReferenceHidden");
                PromocaoFormReferenceHidden.ResetState();
            }

            productModel = product;
            StateHasChanged();

            firstCall = true;
        }
        else if (firstCall)
        {
            Console.WriteLine($"[ProductModal] OnParametersSet - Produto já configurado: {productModel?.Nome ?? "NULL"}");
        }
        else
        {
            Console.WriteLine($"[ProductModal] OnParametersSet - SelectedDTO não é ProdutoGetDTO ou firstCall=true");
        }
    }

    private async Task SubmitAsync()
    {
        try {
           
            
            var productData = await ProductFormReference.GetProductForm();
            
            // Incluir horários do componente de horários
            if (HorarioFormReference != null)
            {
                productData.Horarios = HorarioFormReference.GetHorarios();
            }

     
            
            // Aguardar um pouco para garantir que componentes foram inicializados
            await Task.Delay(50);
            
            // Usar a referência oculta se a da aba for null (tab não visitada)
            var promocaoRef = PromocaoFormReference ?? PromocaoFormReferenceHidden;
         
            
            if (promocaoRef != null)
            {
                try
                {
                    var promocaoData = promocaoRef.GetPromocaoData();
                    
                    if (promocaoData != null)
                    {
                        Console.WriteLine($"[ProductModal] promocaoData.PromocoesPorHorario é null: {promocaoData.PromocoesPorHorario == null}");
                        Console.WriteLine($"[ProductModal] promocaoData.PromocoesPorHorario.Count: {promocaoData.PromocoesPorHorario?.Count ?? -1}");
                        
                        // Agora incluir as promoções por horário
                        productData.PromocoesPorHorario = promocaoData.PromocoesPorHorario ?? new List<ProdutoPromocaoHorarioAddDTO>();
                        
                        // Manter compatibilidade com campos antigos de promoção
                        productData.Promocao = promocaoData.IsPromocao;
                        productData.FimPromocao = promocaoData.FimPromocao;
                        
                        // Não é mais necessário converter preço promocional pois agora é por horário
                        productData.PrecoPromocional = null;
                        
                        if (productData.PromocoesPorHorario != null && productData.PromocoesPorHorario.Any())
                        {
                            Console.WriteLine($"[ProductModal] ✅ Enviando {productData.PromocoesPorHorario.Count} promoções para o backend:");
                            foreach (var promo in productData.PromocoesPorHorario)
                            {
                                Console.WriteLine($"[ProductModal] - {promo.DiaSemana} {promo.HoraInicio}-{promo.HoraFim} R$ {promo.PrecoPromocional:F2}");
                            }
                        }
                        else
                        {
                            Console.WriteLine($"[ProductModal] ❌ Nenhuma promoção configurada no frontend");
                        }
                    }
                    else
                    {
                        productData.PromocoesPorHorario = new List<ProdutoPromocaoHorarioAddDTO>();
                    }
                }
                catch (Exception ex)
                {
                    productData.PromocoesPorHorario = new List<ProdutoPromocaoHorarioAddDTO>();
                }
            }
            else
            {
                productData.PromocoesPorHorario = new List<ProdutoPromocaoHorarioAddDTO>();
            }
            

            var groupsData = AdditionalFormReference.GetGroupForm();
            
            // === DEBUG DETALHADO DOS GRUPOS ===
            if (groupsData != null && groupsData.Count > 0)
            {
                Console.WriteLine($"[ProductModal] 🔍 DETALHES DOS GRUPOS ANTES DO DTO:");
                for (int i = 0; i < groupsData.Count; i++)
                {
                    var grupo = groupsData[i];
                }
            }
            else
            {
                Console.WriteLine($"[ProductModal] ❌ groupsData é null ou vazio");
            }

            ProductTransferDTO productTransferDTO = new ProductTransferDTO
            {
                ProductTransferDataDTO = productData,
                GroupsAdditionalGetDTO = groupsData, 
            };
            
            // === DEBUG DO DTO MONTADO ===

            await Task.Yield();

            if (productTransferDTO.ProductTransferDataDTO == null)
            {
                return;
            }

            await OnSubmit.InvokeAsync((T)(object)productTransferDTO);
        }
        catch (Microsoft.JSInterop.JSDisconnectedException jsEx)
        {
            
            // Tentar fechar o modal via callback se possível
            try
            {
                await OnCancel.InvokeAsync();
            }
            catch 
            {
                // Como último recurso, sinalizar que houve problema
                StateHasChanged();
            }
        }
        catch (Exception err)
        {
            Console.WriteLine($"[ProductModal] ❌ Erro geral: {err.Message}");
            try 
            {
                await ProductFormReference.ErrorForm(err);
            }
            catch (Microsoft.JSInterop.JSDisconnectedException)
            {
                Console.WriteLine("[ProductModal] Erro adicional: JavaScript desconectado durante exibição de erro");
            }
        } finally {
            try 
            {
                if (ComponentIsLoaded is EventCallback isLoaded)
                {
                    await isLoaded.InvokeAsync();
                }
            }
            catch (Microsoft.JSInterop.JSDisconnectedException)
            {
                // Ignorar erros de JavaScript quando o circuito está desconectado
                Console.WriteLine("[ProductModal] JavaScript desconectado durante ComponentIsLoaded");
                
                // Se chegamos até aqui, significa que os dados foram salvos
                // Recarregar a página para mostrar as alterações
                try
                {
                    await Task.Delay(1000); // Aguardar um pouco
                    await JSRuntime.InvokeVoidAsync("location.reload");
                }
                catch
                {
                    Console.WriteLine("[ProductModal] Não foi possível recarregar página automaticamente");
                }
            }
            catch (Exception finalEx)
            {
                Console.WriteLine($"[ProductModal] Erro no finally: {finalEx.Message}");
            }
        }
    }

    [JSInvokable("HandleModalEnterKey")]
    public async Task HandleModalEnterKey()
    {
        if (IsLoading || StateContainer.SecondaryModalIsOpen)
        {
            return;
        }

        await SubmitAsync();
    }

    [JSInvokable("HandleEscapeKey")]
    public async Task HandleEscapeKey()
    {
        await CancelAsync();
    }

    private async Task CancelAsync()
    {
        Console.WriteLine($"[ProductModal] CancelAsync - Resetando estados antes de fechar");
        
        // Reset do estado ao cancelar
        if (PromocaoFormReference != null)
        {
            PromocaoFormReference.ResetState();
        }
        if (PromocaoFormReferenceHidden != null)
        {
            PromocaoFormReferenceHidden.ResetState();
        }
        
        firstCall = false; // Permitir nova inicialização na próxima abertura
        
        await OnCancel.InvokeAsync();
    }

    private int ValidateSelectedCompanyID()
    {
        if (usuario != null && EmpresaService.EmpresaSelecionada == 0)
        {
            return usuario.EmpresaID ?? 0;
        }

        return EmpresaService.EmpresaSelecionada;
    }

    async Task GetUser()
    {
        HttpClient.DefaultRequestHeaders.Authorization =
            new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);

        var result = await HttpClient.GetFromJsonAsync<UsuarioGetDTO>("/api/authentication/getCompanyID");
        usuario = result;
    }
}

<div class="form">
    <div class="form-header">
        <div class="header">
            <div class="content-header">
                <div class="icon"><i class="fa-solid fa-box-open"></i></div>
                <div class="title-container">
                    <h4 class="title">@Title</h4>
                </div>
            </div>
            <div class="close" @onclick="CancelAsync"><i class="fa-solid fa-x"></i></div>
        </div>
    </div>
    <RadzenTabs RenderMode="TabRenderMode.Client" TabPosition="TabPosition.Top" @bind-SelectedIndex=@selectedIndex>
        <Tabs>
            <RadzenTabsItem Text="Produtos">
                <ProductForm CategoriesDataAPI="@CategoriesDataAPI" OnOpenCategoryModal="@OnOpenCategoryModal" ComponentIsLoaded="@ComponentIsLoaded"
                             @ref="ProductFormReference" productSelected="productModel" />
            </RadzenTabsItem>
            <RadzenTabsItem Text="Adicionais">
                <AdditionalForm @ref="AdditionalFormReference" SelectedProduct="productModel" />
            </RadzenTabsItem>
            <RadzenTabsItem Text="Horários">
                <HorarioForm @ref="HorarioFormReference" SelectedProduct="productModel" />
            </RadzenTabsItem>
            <RadzenTabsItem Text="Promoção">
                <PromocaoTab @ref="PromocaoFormReference" 
                             SelectedProduct="productModel" />
            </RadzenTabsItem>
        </Tabs>
    </RadzenTabs>
    
    @* Componente PromocaoTab sempre renderizado (oculto) para garantir inicialização *@
    <div style="display: none;">
        <PromocaoTab @ref="PromocaoFormReferenceHidden" 
                     SelectedProduct="productModel" />
    </div>
    <div class="form-footer">
        <button type="button" @onclick="CancelAsync" class="cancel rz-ripple" disabled="@IsLoading"><span>Cancelar</span></button>
        <button type="button" @onclick="SubmitAsync" class="confirm rz-ripple button-green" disabled="@IsLoading">
            @if (IsLoading)
            {
                <SpinnerLoader PrimaryColor="#FFFFFF" SecondaryColor="#118AB2" Size="20" />
            }
            else
            {
                <span>Salvar</span>
            }
        </button>
    </div>
</div>

