@typeparam T;
@typeparam SelectedDTOParam

@inject IJSRuntime JSRuntime;
@inject HttpClient HttpClient;
@inject SelectCompanyService EmpresaService;
@inject Cardápio.Client.Pages.Produto.ProdutoService ProdutoService;
@inject Cardápio.Client.Infra.Provider.CustomAuthenticationStateProvider Provider;

@using Cardápio.Client.Components.SelectCompany;
@using System.Collections.ObjectModel;
@using System.Globalization;

@code {
    [Parameter] public string ActionType { get; set; }
    [Parameter] public EventCallback<T> OnSubmit { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }
    [Parameter] public SelectedDTOParam? SelectedDTO { get; set; }
    [Parameter] public bool IsLoading { get; set; }
    [Parameter] public EventCallback? ComponentIsLoaded { get; set; }

    private UsuarioGetDTO usuario;

    private string Title = "Exportar produtos";

    private int IDEmpresaSelecionada;

    private bool importCheck { get; set; } = true;
    private RadzenDataGrid<ProdutoGetDTO> dataGrid;
    private ObservableCollection<ProdutoGetDTO> produtos;
    private IList<ProdutoGetDTO> selectedProdutos;
    private ProdutoGetDTO editingProduto;
    private ObservableCollection<EmpresaGetDTO> empresas;
    private ElementReference valorInput;

    private int selectedEmpresa;
    private string token;
    bool allowRowSelectOnRowClick = false;

    private Dictionary<string, string> validationErrors = new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            token = await Provider.GetTokenAsync();
            //await GetUser();
            usuario = Provider.UsuarioOwner;
            IDEmpresaSelecionada = EmpresaService.EmpresaSelecionada;
            await GetProducts();
            await GetEnterprises();
            await JSRuntime.InvokeVoidAsync("handleEscKey", DotNetObjectReference.Create(this));
            await JSRuntime.InvokeVoidAsync("handleModalEnterKey", DotNetObjectReference.Create(this));
            RemoveEmpresaSelecionadaDoDropdown();
        }
    }

    private async Task InitializeInputsMask()
    {
        await JSRuntime.InvokeVoidAsync("applyVMaskerMoney", "priceInput");
    }

    private void RemoveEmpresaSelecionadaDoDropdown()
    {
        if (empresas != null && empresas.Any())
        {
            var empresaARemover = empresas.FirstOrDefault(e => e.ID == IDEmpresaSelecionada);
            if (empresaARemover != null)
            {
                empresas.Remove(empresaARemover);
            }

            StateHasChanged();
        }
    }

    private async Task SubmitAsync()
    {
        try
        {
            var produtosSelecionados = selectedProdutos
                 .Where(p => p != null)
                 .Select(p => new ProdutoExportDTO
                     {
                         ProdutoId = p.ID,
                         Preco = p.Preco ?? 0,
                         GruposID = importCheck ? p.ColGrupoAdicional.ToList() : new(),
                     })
                 .ToList();

            if (produtosSelecionados.Any())
            {
                ExportarProdutosDTO data = new ExportarProdutosDTO
                    {
                        EmpresaIdTo = selectedEmpresa,
                        EmpresaIdFrom = ValidateSelectedCompanyID(),
                        Produtos = produtosSelecionados,
                        ImportCheck = importCheck,
                    };

                if (!await ValidateEntityAsync(data, nameof(data.EmpresaIdTo)))
                {
                    return;
                }

                await OnSubmit.InvokeAsync((T)(object)data);
            }
        } catch (Exception err) 
        {
            Console.WriteLine("error modal " + err.Message);
        }
        finally
        {
            if (ComponentIsLoaded is EventCallback isLoaded)
            {
                await isLoaded.InvokeAsync();
            }
        }
    }

    private async Task CancelAsync()
    {
        editingProduto = null;

        await OnCancel.InvokeAsync();
    }

    [JSInvokable("HandleModalEnterKey")]
    public async Task HandleModalEnterKey()
    {
        if (IsLoading)
        {
            return;
        }

        StateHasChanged();
        await SubmitAsync();
    }

    [JSInvokable("HandleEscapeKey")]
    public async Task HandleEscapeKey()
    {
        await CancelAsync();
    }

    private async Task<bool> ValidateEntityAsync<GenericValidate>(GenericValidate entity, params string[] requiredFields)
    {
        var validator = new ValidationService<GenericValidate>();
        var validationResult = validator.Validate(entity, requiredFields);

        if (!validationResult.IsValid)
        {
            validationErrors = validationResult.Errors;
            StateHasChanged();
            return false;
        }

        validationErrors.Clear();
        return true;
    }

    public async Task GetProducts()
    {
        produtos = await ProdutoService.GetData(EmpresaService.EmpresaSelecionada);
    }

    public async Task GetEnterprises()
    {
        try
        {
            HttpClient.DefaultRequestHeaders.Authorization =
                new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);

            var result = await HttpClient.GetFromJsonAsync<List<EmpresaGetDTO>>("/api/enterprise/GetEnterprises");
            empresas = new ObservableCollection<EmpresaGetDTO>(result);
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
        }
    }

    private async void OnCellClick(DataGridCellMouseEventArgs<ProdutoGetDTO> args)
    {
        if (args.Column.Property == "Preco")
        {
            editingProduto = args.Data;
            dataGrid.EditRow(args.Data);

            await Task.Yield();

            await InitializeInputsMask();
            await Task.Yield();

            await valorInput.FocusAsync();
        }
    }

    private void OnUpdatePreco(string? novoPrecoStr)
    {
        if (string.IsNullOrWhiteSpace(novoPrecoStr))
        {
            editingProduto.Preco = 0;
        }
        else
        {
            var precoSemSimbolo = novoPrecoStr.Replace("R$", "").Trim();

            if (decimal.TryParse(precoSemSimbolo, NumberStyles.Number, new CultureInfo("pt-BR"), out var novoPreco))
            {
                editingProduto.Preco = novoPreco;
            }
            else
            {
                editingProduto.Preco = 0;
            }
        }

        StateHasChanged();
    }

    private void OnBlurEditing()
    {
        if (editingProduto != null)
        {
            if (editingProduto.Preco == null)
            {
                editingProduto.Preco = 0;
            }

            StateHasChanged();
        }

        editingProduto = null;
    }

    async Task GetUser()
    {
        HttpClient.DefaultRequestHeaders.Authorization =
            new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);

        usuario = await HttpClient.GetFromJsonAsync<UsuarioGetDTO>("/api/authentication/getCompanyID");
    }

    private int ValidateSelectedCompanyID()
    {
        if (EmpresaService.EmpresaSelecionada == 0)
        {
            return usuario.EmpresaID ?? 0;
        }

        return EmpresaService.EmpresaSelecionada;
    }
}

<div class="form">
    <div class="form-header">
        <div class="header">
            <div class="content-header">
                <div class="icon"><i class="fa-solid fa-file-export"></i></div>
                <div class="title-container">
                    <h4 class="title">@Title</h4>
                </div>
            </div>
            <div class="close" @onclick="CancelAsync"><i class="fa-solid fa-x"></i></div>
        </div> 
    </div>
    <div class="form-body">
        <div class="inputs-container">
            <div class="inputs">
                <label>Produtos para exportar</label>
                <div>
                    <RadzenDataGrid @ref="dataGrid"
                                    AllowRowSelectOnRowClick="@allowRowSelectOnRowClick"
                                    AllowFiltering="true"
                                    FilterPopupRenderMode="PopupRenderMode.OnDemand"
                                    FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                                    PageSize="4"
                                    AllowColumnResize="true"
                                    AllowSorting="true"
                                    Data="@produtos"
                                    TItem="ProdutoGetDTO"
                                    SelectionMode="DataGridSelectionMode.Multiple"
                                    @bind-Value="@selectedProdutos"
                                    Style="width: 100%; max-height: 250px; min-height: 250px; height: 100%;"
                                    CellClick="@OnCellClick">
                        <Columns>
                            <RadzenDataGridColumn MinWidth="45px" Width="45px" Sortable="false" Filterable="false" Resizable="true">
                                <HeaderTemplate>
                                    <RadzenCheckBox TabIndex="-1" TriState="false" TValue="bool?" InputAttributes="@(new Dictionary<string,object>(){ { "aria-label", "Select all items" }, { "style", "transform: scale(1.2);" }})"
                                                    Value="@(selectedProdutos == null || selectedProdutos?.Any() != true ? false : !produtos.All(i => selectedProdutos.Contains(i)) ? null : produtos.Any(i => selectedProdutos.Contains(i)))"
                                                    Change="@(args => selectedProdutos = args == true ? produtos.ToList() : null)" />
                                </HeaderTemplate>
                                <Template Context="data">
                                    <RadzenCheckBox TabIndex="-1"
                                                    TriState="false"
                                                    Value="@(selectedProdutos != null && selectedProdutos.Contains(data))"
                                                    InputAttributes="@(new Dictionary<string,object>(){ { "aria-label", "Select item" }})"
                                                    TValue="bool"
                                                    Change=@(args => { if(!allowRowSelectOnRowClick) { dataGrid.SelectRow(data); }}) />
                                </Template>
                            </RadzenDataGridColumn>

                            <RadzenDataGridColumn TItem="ProdutoGetDTO" Property="Nome" Title="Nome" Filterable="false" Sortable="false" Resizable="true" MinWidth="100px">
                                <Template Context="data">
                                    <div style="overflow-x: auto; max-height: 100px; white-space: nowrap; box-sizing: border-box; padding-right: 16px; width: 100%;">@(data.Nome)</div>
                                </Template>
                            </RadzenDataGridColumn>

                            <RadzenDataGridColumn TItem="ProdutoGetDTO" Property="Categoria" Title="Categoria" Filterable="false" Sortable="false" Resizable="true" MinWidth="150px">
                                <Template Context="data">
                                    <div style="overflow-x: auto; max-height: 100px; white-space: nowrap; box-sizing: border-box; padding-right: 16px; width: 100%;">@(data.Categoria)</div>
                                </Template>
                            </RadzenDataGridColumn>

                            <RadzenDataGridColumn TItem="ProdutoGetDTO" Property="Preco" Title="Preço" Filterable="false" Sortable="false" Resizable="true" Frozen="false" CssClass="number" MinWidth="200px">
                                <Template Context="data">
                                    @if (editingProduto == data)
                                    {
                                        <input @ref="valorInput" id="priceInput" type="text" value="@editingProduto.Preco"
                                               @oninput="e => OnUpdatePreco(e.Value?.ToString())"
                                               class="number" @onblur="OnBlurEditing" />
                                    }
                                    else
                                    {
                                        <div class="number">
                                            @(
                                                String.Format(new System.Globalization.CultureInfo("pt-BR"), "{0:C}", data.Preco)
                                                )
                                        </div>
                                    }
                                </Template>
                            </RadzenDataGridColumn>
                        </Columns>
                    </RadzenDataGrid>
                </div>
            </div>
            <div class="inputs">
                <label>Empresa que receberá os produtos</label>
                <RadzenDropDown @bind-Value="selectedEmpresa"
                                Data="empresas"
                                TextProperty="Nome"
                                ValueProperty="ID"
                                FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                                Placeholder="Selecione uma empresa"
                                AllowFiltering="true"
                                class="export-dropdown" />
                <span class="error">@(validationErrors.GetValueOrDefault("EmpresaId") != null ? "Seleciona uma empresa" : "")</span>
            </div>
            <div class="inputs-checkbox">

                <RadzenCheckBox id="importCheck"
                                TValue="bool"
                                @bind-Value="importCheck"
                                Style="margin-right: 10px;" />
                <label>Importar grupos de adicionais</label>
            </div>
        </div>
     </div>
    <div class="form-footer">
        <button type="button" @onclick="CancelAsync" class="cancel rz-ripple" disabled="@IsLoading"><span>Cancelar</span></button>
        <button type="button" @onclick="SubmitAsync" class="confirm rz-ripple button-green" disabled="@IsLoading">
            @if (IsLoading)
            {
                <SpinnerLoader PrimaryColor="#FFFFFF" SecondaryColor="#118AB2" Size="20" />
            }
            else
            {
                <span>Salvar</span>
            }
        </button>
    </div>
</div>

<style>
    .rz-numeric-input {
        font-family: 'Montserrat' !important;
    }

    .rz-chkbox-box.rz-state-active {
        background-color: #118AB2 !important;
        border: #118AB2 !important;
    }

    body .export-dropdown:hover {
        border: 1px solid #D0D5DD !important;
    }

    .rz-dropdown-panel {
        z-index: 100001 !important;
    }

    body .export-dropdown {
        font-size: 0.875rem;
        line-height: 1.25rem;
        color: #073B4C;
        font-weight: 500;
        border: 1px solid #D0D5DD;
        border-radius: 0.375rem;
        letter-spacing: normal;
        transition: border 0.2s ease;
        outline: none;
        box-shadow: 4px 4px 3px rgba(0, 0, 0, 0.02);
        padding: 9px 12px;
        width: 100%;
        min-width: initial !important;
        max-width: initial !important;
        font-size: 14px !important;
    }

    @@media screen and (max-width: 590px) {
        body .export-dropdown {
            max-width: initial !important;
        }
    }

    .rz-dropdown-item {
        font-size: 14px !important;
    }
</style>