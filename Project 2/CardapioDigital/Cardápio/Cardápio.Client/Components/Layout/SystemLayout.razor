@inherits LayoutComponentBase
@inject HttpClient HttpClient;
@inject IJSRuntime jsRuntime;
@inject NavigationManager NavigationManager;
@inject Cardápio.Client.Infra.Provider.CustomAuthenticationStateProvider Provider;

@code {
    private UsuarioGetDTO usuarioOwner;
    private UsuarioClienteGetDTO usuarioClient;

    private string token = null;
    private int screenWidth;
    private bool isLoading = true;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            if (!NavigationManager.Uri.StartsWith("https://localhost:7243/loja/", StringComparison.OrdinalIgnoreCase))
            {
                await Provider.GetOwnerUser();
                usuarioOwner = Provider.UsuarioOwner;
            }

            if (Provider.UsuarioOwner == null)
            {
                await Provider.GetClientUser();
                usuarioClient = Provider.UsuarioClienteGetDTO;
            }

            screenWidth = await jsRuntime.InvokeAsync<int>("eval", "window.innerWidth");
            await Task.Yield();

            if (screenWidth <= 800)
            {
                IsCollapsed = true;
            }

            if (Provider.UsuarioOwner == null && Provider.UsuarioClienteGetDTO == null)
            {
                Provider.IsLoading = false;
            }

            isLoading = false;
            StateHasChanged();
        }
    }

    async void Logout()
    {
        isLoading = true;
        ToggleSidebar(); // Fecha o sidebar antes de fazer logout
        usuarioOwner = null;
        usuarioClient = null;

        await Provider.LogoutAsync();
        StateHasChanged();
        NavigationManager.NavigateTo("/login", true);
    }
}

@if (usuarioOwner != null && isLoading == false && Provider.IsLoading == false)
{
