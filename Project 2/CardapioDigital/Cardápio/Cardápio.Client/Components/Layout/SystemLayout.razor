}

@if (isLoading || Provider.IsLoading)
{
    <div class="loader-initial">
        <SpinnerLoader PrimaryColor="#272A2D" SecondaryColor="#ffffff" Size="90" />
    </div>
}

@code {
    private bool IsCollapsed = true;

    private string SidebarCssClass => IsCollapsed ? "sidebar collapsed" : "sidebar";

    private void ToggleSidebar()
    {
        IsCollapsed = !IsCollapsed;
        StateHasChanged();
    }
}
