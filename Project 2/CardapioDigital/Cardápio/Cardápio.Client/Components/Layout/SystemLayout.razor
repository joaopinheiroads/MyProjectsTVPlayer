@if (usuarioOwner == null && isLoading == false && Provider.IsLoading == false)
{
    if (NavigationManager.Uri.StartsWith("https://localhost:7243/loja/", StringComparison.OrdinalIgnoreCase)) //alterado
    {
        <main style="padding-left: 0 !important; padding-right: 0 !important;">
            @Body
